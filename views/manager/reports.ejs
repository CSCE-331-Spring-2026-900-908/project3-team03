<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manager Reports</title>
  <!-- TODO: CSS styles for later -->
  <link rel="stylesheet" href="/css/manager_reports.css" />
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <h2 class="sidebar-title">Manager</h2>
      <hr class="sidebar-divider" />

      <a href="/manager/dashboard" class="sidebar-link">Dashboard</a>
      <a href="/manager/reports" class="sidebar-link active">Reports</a>
      <a href="/manager/inventory" class="sidebar-link">Inventory</a>
      <a href="/manager/menu" class="sidebar-link">Menu</a>
      <a href="/manager/employees" class="sidebar-link">Employees</a>
    </aside>

    <main class="main">
      <header class="page-header">
        <h1>Reports</h1>
      </header>

      <div class="tabs">
        <button class="tab-button active" data-tab="x-report">X-Report</button>
        <button class="tab-button" data-tab="sales-report">Sales Report</button>
        <button class="tab-button" data-tab="usage-report">Product Usage</button>
        <button class="tab-button" data-tab="z-report">Z-Report</button>
      </div>

      <!-- X-REPORT -->
      <section class="tab-panel active" id="x-report">
        <div class="report-grid">
          <div class="panel">
            <h2>X-Report Options</h2>

            <form method="GET" action="/manager_reports_x" class="form-stack">
              <input type="date" name="date" value="<%= xReport?.date || '' %>" />

              <div class="form-row">
                <div class="form-group">
                  <select name="beginHour">
                    <% for (let i = 0; i < 24; i++) { %>
                      <option value="<%= i %>" <%= xReport?.beginHour == i ? 'selected' : '' %>><%= i %>:00</option>
                    <% } %>
                  </select>
                  <label>Begin Hour</label>
                </div>

                <div class="form-group">
                  <select name="endHour">
                    <% for (let i = 0; i < 24; i++) { %>
                      <option value="<%= i %>" <%= xReport?.endHour == i ? 'selected' : '' %>><%= i %>:00</option>
                    <% } %>
                  </select>
                  <label>End Hour</label>
                </div>
              </div>

              <button type="submit" class="primary-btn">Generate X-Report</button>
            </form>

            <p class="status-text"><%= xReport?.status || '' %></p>
          </div>

          <div class="panel">
            <h2 class="section-title">Report Summary</h2>

            <div class="metric-row">
              <div class="metric-card">
                <span class="metric-label">Paid Orders</span>
                <span class="metric-value"><%= xReport?.orders ?? 0 %></span>
              </div>
              <div class="metric-card">
                <span class="metric-label">Discards</span>
                <span class="metric-value"><%= xReport?.discards ?? 0 %></span>
              </div>
              <div class="metric-card">
                <span class="metric-label">Total Sales</span>
                <span class="metric-value">$<%= xReport?.sales ?? '0.00' %></span>
              </div>
            </div>

            <div class="summary-list">
              <div class="summary-item"><span>Card Payments:</span><span><%= xReport?.cardPayments ?? 0 %></span></div>
              <div class="summary-item"><span>Cash Payments:</span><span><%= xReport?.cashPayments ?? 0 %></span></div>
              <div class="summary-item"><span>Avg. Revenue / Order:</span><span>$<%= xReport?.avgRevenue ?? '0.00' %></span></div>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</body>
</html>