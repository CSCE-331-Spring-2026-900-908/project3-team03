<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manager Inventory</title>
  <link rel="stylesheet" href="/css/manager_inventory.css" />
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <h2 class="sidebar-title">Manager</h2>
      <hr class="sidebar-divider" />

      <a href="/manager/dashboard" class="sidebar-link">Dashboard</a>
      <a href="/manager/reports" class="sidebar-link">Reports</a>
      <a href="/manager/inventory" class="sidebar-link active">Inventory</a>
      <a href="/manager/menu" class="sidebar-link">Menu</a>
      <a href="/manager/employees" class="sidebar-link">Employees</a>

      <hr class="sidebar-divider" />

      <a href="/cashier" class="sidebar-link">Switch to Cashier</a>
    </aside>

    <main class="main">
      <div class="page-header">
        <h1>Inventory</h1>
      </div>

      <section class="panel">
        <form class="action-row" method="POST" action="/manager/inventory/add">
          <input type="text" name="itemName" placeholder="Item Name" required />
          <input type="number" name="onHand" placeholder="On Hand" min="0" required />
          <input type="number" name="reorder" placeholder="Reorder" min="0" required />
          <button type="submit" class="primary-btn">Add Item</button>
        </form>

        <form class="action-row" method="POST" action="/manager/inventory/update-quantity">
          <input type="text" name="itemName" placeholder="Item Name" required />
          <input type="number" name="onHand" placeholder="New Quantity" min="0" required />
          <button type="submit" class="secondary-btn">Update Quantity</button>
        </form>

        <form class="action-row" method="POST" action="/manager/inventory/delete">
          <input type="text" name="deleteName" placeholder="Ingredient name" required />
          <button type="submit" class="danger-btn">Delete by name</button>
        </form>

        <% if (statusMessage) { %>
          <p class="status-message"><%= statusMessage %></p>
        <% } %>
      </section>

      <section class="panel">
        <div class="panel-header">
          <h2>Inventory Items</h2>
        </div>

        <% if (inventoryItems && inventoryItems.length > 0) { %>
          <table>
            <thead>
              <tr>
                <th>Item Name</th>
                <th>On Hand</th>
                <th>Level</th>
                <th>Reorder</th>
              </tr>
            </thead>
            <tbody>
              <% inventoryItems.forEach(item => { %>
                <tr>
                  <td><%= item.name %></td>
                  <td><%= item.onHand %></td>
                  <td><%= item.parLevel %></td>
                  <td><%= item.reorder %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <p class="empty-text">No inventory items found.</p>
        <% } %>
      </section>
    </main>
  </div>
</body>
</html>