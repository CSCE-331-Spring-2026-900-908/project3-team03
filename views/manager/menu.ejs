<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manager Menu</title>
    <link rel="stylesheet" href="/css/manager_menu.css" />
</head>
<body>
    <div class="layout">
        <aside class="sidebar">
        <h2 class="sidebar-title">Manager</h2>
        <hr class="sidebar-divider" />

        <a href="/manager/dashboard" class="sidebar-link">Dashboard</a>
        <a href="/manager/reports" class="sidebar-link">Reports</a>
        <a href="/manager/inventory" class="sidebar-link">Inventory</a>
        <a href="/manager/menu" class="sidebar-link active">Menu</a>
        <a href="/manager/employees" class="sidebar-link">Employees</a>

        <hr class="sidebar-divider" />

        <a href="/cashier/menu" class="sidebar-link">Switch to Cashier</a>
        </aside>

        <main class="main">
        <!-- TOP SECTION -->
        <header class="topbar">
            <div class="topbar-left">
            <h1>Menu Items</h1>
            </div>
            <a href="/manager/menu" class="refresh-btn">Refresh</a>
        </header>

        <!-- STATUS -->
        <% if (statusMessage) { %>
            <div class="status-message"><%= statusMessage %></div>
        <% } %>

        <!-- MAIN CONTENT -->
        <div class="content">
            <section class="table-panel">
                <table class="menu-table">
                    <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Base Price</th>
                        <th>Active</th>
                    </tr>
                    </thead>
                    <tbody>
                    <% if (menuItems && menuItems.length > 0) { %>
                        <% menuItems.forEach(item => { %>
                        <tr
                            class="<%= selectedItem && selectedItem.menu_item_id === item.menu_item_id ? 'selected-row' : '' %>"
                            onclick="window.location.href='/manager/menu?menuItemId=<%= item.menu_item_id %>'"
                            style="cursor: pointer;"
                        >
                            <td><%= item.menu_item_id %></td>
                            <td><%= item.name %></td>
                            <td><%= item.category %></td>
                            <td>$<%= item.base_price %></td>
                            <td><%= item.active ? 'Yes' : 'No' %></td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                        <td colspan="5" class="empty-cell">No menu items found.</td>
                        </tr>
                    <% } %>
                    </tbody>
                </table>
            </section>

            <section class="menu-actions-grid">
                <section class="action-card action-card-highlight">
                    <h2>Edit / Add</h2>
                    <label>Selected item:</label>
                    <div class="selected-item">
                        <%= selectedItem ? `${selectedItem.menu_item_id} - ${selectedItem.name}` : '(none)' %>
                    </div>
                </section>

                <section class="action-card">
                    <h3>Price & Status</h3>
                    <form method="POST" action="/manager/menu/update-price" class="stack-form">
                        <input type="hidden" name="menuItemId" value="<%= selectedItem ? selectedItem.menu_item_id : '' %>" />
                        <input type="text" name="newPrice" placeholder="e.g. 6.50" />
                        <button type="submit">Update Price</button>
                    </form>

                    <form method="POST" action="/manager/menu/toggle-active" class="stack-form">
                        <input type="hidden" name="menuItemId" value="<%= selectedItem ? selectedItem.menu_item_id : '' %>" />
                        <button type="submit">Toggle Active/Inactive</button>
                    </form>
                </section>

                <section class="action-card">
                    <h3>Add Menu Item</h3>
                    <form method="POST" action="/manager/menu/add" class="stack-form">
                        <input type="text" name="name" placeholder="Name" required />

                        <select name="category" required>
                        <option value="">Category</option>
                        <% if (categories && categories.length > 0) { %>
                            <% categories.forEach(category => { %>
                            <option value="<%= category %>"><%= category %></option>
                            <% }) %>
                        <% } %>
                        </select>

                        <input type="text" name="basePrice" placeholder="Base Price (e.g. 6.00)" required />
                        <textarea name="description" rows="3" placeholder="Description (optional)"></textarea>

                        <details class="style-details">
                            <summary>SVG colors for new drink</summary>
                            <p class="card-helper">Used by kiosk drink previews. Ignored when adding an ADDON.</p>

                            <label>Visual Category</label>
                            <input type="text" name="styleCategory" value="<%= defaultDrinkStyle.category %>" />

                            <div class="color-grid">
                                <label>Lid <input type="color" name="lidColor" value="<%= defaultDrinkStyle.lid_color %>" /></label>
                                <label>Straw <input type="color" name="strawMain" value="<%= defaultDrinkStyle.straw_main %>" /></label>
                                <label>Straw Shadow <input type="color" name="strawShadow" value="<%= defaultDrinkStyle.straw_shadow %>" /></label>
                                <label>Liquid Top <input type="color" name="liquidTop" value="<%= defaultDrinkStyle.liquid_top %>" /></label>
                                <label>Liquid Mid <input type="color" name="liquidMid" value="<%= defaultDrinkStyle.liquid_mid %>" /></label>
                                <label>Liquid Bottom <input type="color" name="liquidBottom" value="<%= defaultDrinkStyle.liquid_bottom %>" /></label>
                                <label>Accent <input type="color" name="accentColor" value="<%= defaultDrinkStyle.accent_color %>" /></label>
                                <label>Boba <input type="color" name="bobaColor" value="<%= defaultDrinkStyle.boba_color %>" /></label>
                            </div>

                            <label>Accent Type</label>
                            <select name="accentType">
                            <% accentTypes.forEach(type => { %>
                                <option value="<%= type %>" <%= defaultDrinkStyle.accent_type === type ? 'selected' : '' %>><%= type %></option>
                            <% }) %>
                            </select>
                        </details>

                        <label class="checkbox-row">
                        <input type="checkbox" name="active" checked />
                        <span>Active</span>
                        </label>

                        <button type="submit">Add Item</button>
                    </form>
                </section>

                <section class="action-card action-card-wide">
                    <h3>Drink SVG Colors</h3>
                    <% if (selectedItem && selectedItem.category !== 'ADDON' && selectedDrinkStyle) { %>
                        <p class="card-helper">Controls the cup SVG colors used in kiosk previews.</p>

                        <form method="POST" action="/manager/menu/update-drink-style" class="stack-form">
                            <input type="hidden" name="menuItemId" value="<%= selectedItem.menu_item_id %>" />

                            <label>Visual Category</label>
                            <input type="text" name="styleCategory" value="<%= selectedDrinkStyle.category %>" />

                            <div class="color-grid">
                                <label>Lid <input type="color" name="lidColor" value="<%= selectedDrinkStyle.lid_color %>" /></label>
                                <label>Straw <input type="color" name="strawMain" value="<%= selectedDrinkStyle.straw_main %>" /></label>
                                <label>Straw Shadow <input type="color" name="strawShadow" value="<%= selectedDrinkStyle.straw_shadow %>" /></label>
                                <label>Liquid Top <input type="color" name="liquidTop" value="<%= selectedDrinkStyle.liquid_top %>" /></label>
                                <label>Liquid Mid <input type="color" name="liquidMid" value="<%= selectedDrinkStyle.liquid_mid %>" /></label>
                                <label>Liquid Bottom <input type="color" name="liquidBottom" value="<%= selectedDrinkStyle.liquid_bottom %>" /></label>
                                <label>Accent <input type="color" name="accentColor" value="<%= selectedDrinkStyle.accent_color %>" /></label>
                                <label>Boba <input type="color" name="bobaColor" value="<%= selectedDrinkStyle.boba_color %>" /></label>
                            </div>

                            <label>Accent Type</label>
                            <select name="accentType">
                            <% accentTypes.forEach(type => { %>
                                <option value="<%= type %>" <%= selectedDrinkStyle.accent_type === type ? 'selected' : '' %>><%= type %></option>
                            <% }) %>
                            </select>

                            <button type="submit">Update SVG Colors</button>
                        </form>
                    <% } else { %>
                        <p class="card-helper">Select a drink menu item to edit SVG colors.</p>
                    <% } %>
                </section>

                <section class="action-card action-card-wide">
                    <h3>Recipe</h3>
                    <p class="card-helper">Ingredients for the selected menu item.</p>

                    <form method="POST" action="/manager/menu/add-recipe-ingredient" class="stack-form">
                        <input type="hidden" name="menuItemId" value="<%= selectedItem ? selectedItem.menu_item_id : '' %>" />

                        <label>Ingredient</label>
                        <select name="ingredientId">
                        <option value="">Select ingredient...</option>
                        <% if (ingredients && ingredients.length > 0) { %>
                            <% ingredients.forEach(ingredient => { %>
                            <option value="<%= ingredient.ingredient_id %>"><%= ingredient.name %></option>
                            <% }) %>
                        <% } %>
                        </select>

                        <label>Qty Required</label>
                        <input type="text" name="qtyRequired" placeholder="e.g. 50" />

                        <button type="submit">Add Ingredient to Recipe</button>
                    </form>

                    <form method="GET" action="/manager/menu/recipe" class="stack-form">
                        <input type="hidden" name="menuItemId" value="<%= selectedItem ? selectedItem.menu_item_id : '' %>" />
                        <button type="submit">View Recipe</button>
                    </form>

                    <% if (recipeLines && recipeLines.length > 0) { %>
                        <div class="recipe-preview">
                        <% recipeLines.forEach(line => { %>
                            <div class="recipe-line"><%= line %></div>
                        <% }) %>
                        </div>
                    <% } %>
                </section>

                <section class="action-card">
                    <h3>Create New Ingredient</h3>
                    <p class="card-helper">Add a missing ingredient before assigning it to a recipe.</p>
                    <form method="POST" action="/manager/menu/create-ingredient" class="stack-form">
                        <input type="hidden" name="menuItemId" value="<%= selectedItem ? selectedItem.menu_item_id : '' %>" />
                        <input type="text" name="ingredientName" placeholder="Ingredient name (e.g. Sakura syrup)" required />
                        <input type="text" name="ingredientUnit" placeholder="Unit (cups, scoops, oz)" required />
                        <input type="text" name="ingredientCategory" placeholder="Category (Tea, Dairy, Topping)" required />
                        <button type="submit">Create Ingredient</button>
                    </form>
                </section>
            </section>
        </div>
        </main>
    </div>
</body>
</html>
