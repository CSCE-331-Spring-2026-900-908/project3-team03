<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manager Dashboard</title>
    <link rel="stylesheet" href="/css/manager_dashboard.css" />
</head>
<body>
    <div class="layout">
        <aside class="sidebar">
        <h2 class="sidebar-title">Manager</h2>
        <hr class="sidebar-divider" />

        <a href="/manager/dashboard" class="sidebar-link">Dashboard</a>
        <a href="/manager/reports" class="sidebar-link">Reports</a>
        <a href="/manager/inventory" class="sidebar-link">Inventory</a>
        <a href="/manager/menu" class="sidebar-link">Menu</a>
        <a href="/manager/employees" class="sidebar-link">Employees</a>

        <hr class="sidebar-divider" />

        <a href="/cashier/menu" class="sidebar-link">Switch to Cashier</a>
        </aside>

        <main class="main">
        <div class="topbar">
            <h1 class="page-title">Dashboard</h1>
            <a class="refresh-btn" href="/manager/dashboard">Refresh</a>
        </div>

        <section class="cards">
            <div class="card">
            <div class="card-label">Sales Today</div>
            <div class="card-value">$<%= salesToday ?? "0.00" %></div>
            </div>

            <div class="card">
            <div class="card-label">Orders Today</div>
            <div class="card-value"><%= ordersToday ?? 0 %></div>
            </div>

            <div class="card">
            <div class="card-label">Avg Order</div>
            <div class="card-value">$<%= avgOrderToday ?? "0.00" %></div>
            </div>
        </section>

        <section class="tables-row">
            <div class="panel panel-large">
            <div class="panel-header">
                <h3>Recent Orders (Today)</h3>
                <a href="/manager/reports" class="panel-link">Open Reports</a>
            </div>

            <% if (recentOrders && recentOrders.length > 0) { %>
                <table>
                <thead>
                    <tr>
                    <th>Order #</th>
                    <th>Time</th>
                    <th>Status</th>
                    <th>Pay</th>
                    <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    <% recentOrders.forEach(order => { %>
                    <tr>
                        <td><%= order.order_id %></td>
                        <td><%= order.created_at %></td>
                        <td><%= order.status %></td>
                        <td><%= order.payment_method %></td>
                        <td>$<%= order.total %></td>
                    </tr>
                    <% }) %>
                </tbody>
                </table>
            <% } else { %>
                <div class="empty">No recent orders for today.</div>
            <% } %>
            </div>

            <div class="panel panel-small">
            <div class="panel-header">
                <h3>Low Stock Alerts</h3>
            </div>

            <% if (lowStock && lowStock.length > 0) { %>
                <table>
                <thead>
                    <tr>
                    <th>Ingredient</th>
                    <th>Qty</th>
                    <th>Reorder</th>
                    </tr>
                </thead>
                <tbody>
                    <% lowStock.forEach(item => { %>
                    <tr>
                        <td><%= item.name %></td>
                        <td><%= item.quantity %></td>
                        <td><%= item.reorder_point %></td>
                    </tr>
                    <% }) %>
                </tbody>
                </table>
            <% } else { %>
                <div class="empty">No low stock alerts.</div>
            <% } %>
            </div>
        </section>
        </main>
    </div>
</body>
</html>