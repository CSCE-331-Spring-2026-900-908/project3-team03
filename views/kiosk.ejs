<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kiosk</title>
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background: #f3f4f6;
            color: #111827;
        }
        .page {
            max-width: 1450px;
            margin: 0 auto;
            padding: 24px;
        }
        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        .topbar h1 {
            margin: 0;
            font-size: 2rem;
        }
        .topbar a {
            text-decoration: none;
            background: #111827;
            color: white;
            padding: 10px 14px;
            border-radius: 10px;
        }
        .layout {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 24px;
            align-items: start;
        }
        .panel {
            background: white;
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 10px 28px rgba(0,0,0,0.08);
        }
        .section-title {
            margin: 0 0 14px 0;
            font-size: 1.35rem;
        }
        .category-tabs {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 18px;
        }
        .tab-btn {
            border: none;
            border-radius: 999px;
            padding: 12px 18px;
            font-weight: 700;
            cursor: pointer;
            background: #e5e7eb;
            color: #111827;
        }
        .tab-btn.active {
            background: #2563eb;
            color: white;
        }
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
            gap: 14px;
        }
        .item-btn {
            border: 2px solid #d1d5db;
            border-radius: 14px;
            background: #f9fafb;
            padding: 18px;
            text-align: left;
            cursor: pointer;
            min-height: 108px;
        }
        .item-btn:hover {
            border-color: #2563eb;
        }
        .item-btn.selected {
            background: #dbeafe;
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
        }
        .item-btn h3 {
            margin: 0 0 8px 0;
            font-size: 1.1rem;
        }
        .item-btn p {
            margin: 0;
            color: #4b5563;
            font-size: 0.95rem;
        }
        .addons {
            margin-top: 22px;
        }
        .addon-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
        }
        .addon-btn {
            border: 2px solid #d1d5db;
            border-radius: 12px;
            background: white;
            padding: 12px;
            cursor: pointer;
            font-weight: 700;
        }
        .addon-btn.selected {
            background: #dbeafe;
            border-color: #2563eb;
        }
        .selected-box {
            margin-top: 20px;
            padding: 16px;
            border-radius: 14px;
            background: #eff6ff;
            border: 1px solid #bfdbfe;
        }
        .selected-box h3 {
            margin-top: 0;
        }
        .qty-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 12px;
            flex-wrap: wrap;
        }
        .qty-btn, .action-btn, .cart-btn {
            border: none;
            border-radius: 10px;
            padding: 10px 14px;
            font-weight: 700;
            cursor: pointer;
        }
        .qty-btn { background: #d1d5db; }
        .action-btn { background: #2563eb; color: white; }
        .cart-btn.secondary { background: #6b7280; color: white; }
        .cart-btn.danger { background: #dc2626; color: white; }
        .order-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin: 16px 0;
        }
        .order-item {
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 14px;
            background: #f9fafb;
        }
        .order-item h3 {
            margin: 0 0 6px 0;
        }
        .total {
            font-size: 1.35rem;
            font-weight: 800;
            margin: 18px 0;
        }
        .muted {
            color: #6b7280;
        }
        .cart-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        .section-title {
            color: #222;
        }

        .item-btn {
            color: #111827;
        }

        .item-btn h3 {
            color: #111827 !important;
        }

        .item-btn p {
            color: #4b5563 !important;
        }

        .addon-btn {
            color: #111827;
        }

        .selected-box,
        .selected-box h3,
        .selected-box div,
        .selected-box span,
        .selected-box strong {
            color: #111827;
        }

        .qty-btn {
            color: #111827;
        }

        .cart-btn.secondary {
            color: white;
        }

        .action-btn {
            color: white;
        }
        .customize-overlay {
            position: fixed;
            inset: 0;
            background: rgba(17, 24, 39, 0.55);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            z-index: 1000;
        }
        .customize-overlay.hidden {
            display: none;
        }
        .customize-modal {
            width: min(980px, 100%);
            max-height: 92vh;
            overflow-y: auto;
            background: white;
            border-radius: 22px;
            box-shadow: 0 24px 64px rgba(0,0,0,0.2);
            padding: 24px;
        }
        .customize-header {
            display: flex;
            justify-content: space-between;
            align-items: start;
            gap: 16px;
            margin-bottom: 18px;
        }
        .customize-header h2 {
            margin: 0 0 6px 0;
        }
        .close-btn {
            border: none;
            border-radius: 10px;
            background: #e5e7eb;
            color: #111827;
            font-weight: 700;
            padding: 10px 14px;
            cursor: pointer;
        }
        .customize-layout {
            display: grid;
            grid-template-columns: 1.1fr 1fr;
            gap: 22px;
        }
        .customize-preview {
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            padding: 16px;
        }
        .option-section {
            margin-bottom: 18px;
        }
        .option-section h3 {
            margin: 0 0 10px 0;
            font-size: 1rem;
        }
        .choice-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 10px;
        }
        .choice-btn {
            border: 2px solid #d1d5db;
            border-radius: 12px;
            background: #f9fafb;
            padding: 12px;
            font-weight: 700;
            color: #111827;
            cursor: pointer;
        }
        .choice-btn.selected {
            background: #dbeafe;
            border-color: #2563eb;
        }
        .customize-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 20px;
        }
        .hidden {
            display: none;
        }
        @media (max-width: 960px) {
            .layout { grid-template-columns: 1fr; }
            .customize-layout { grid-template-columns: 1fr; }
        }
        #drinkPreviewMount {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            min-height: 320px;
            padding: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 12px;
        }

        #drinkPreviewMount svg {
            width: 260px;
            height: auto;
            display: block;
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="topbar">
            <div>
                <h1>Self Service Kiosk</h1>
                <div class="muted">Database-connected menu items and orders</div>
            </div>
        </div>

        <div class="layout">
            <div class="panel">
                <h2 class="section-title">Drink preview</h2>
                <div id="drinkPreviewMount"></div>

                <h2 class="section-title" style="margin-top: 24px;">Choose a category</h2>
                <div class="category-tabs" id="categoryTabs"></div>

                <h2 class="section-title">Menu items</h2>
                <div class="menu-grid" id="menuGrid"></div>

                <div class="selected-box">
                    <h3>Current selection</h3>
                    <div id="selectedDrink" class="muted">No drink selected yet</div>
                    <div id="selectedOptions" class="muted" style="margin-top:8px;">Choose a drink to customize sugar, ice, and add ons</div>

                    <div class="qty-row">
                        <span>Quantity</span>
                        <button class="qty-btn" id="minusQty" type="button">-</button>
                        <strong id="qtyValue">1</strong>
                        <button class="qty-btn" id="plusQty" type="button">+</button>
                        <button class="action-btn" id="addToOrder" type="button">Add to order</button>
                    </div>
                </div>
            </div>

            <div class="panel">
                <h2 class="section-title">Your order</h2>
                <div id="orderList" class="order-list">
                    <div class="muted">Your order is empty</div>
                </div>
                <div class="total">Total $<span id="orderTotal">0.00</span></div>
                <div class="cart-actions">
                    <button class="cart-btn secondary" id="clearOrder" type="button">Clear order</button>
                    <button class="cart-btn" id="checkoutOrder" type="button">Checkout</button>
                </div>
                <p class="muted" style="margin-top:14px;">Powered by database integration. Menu items are fetched from the server.</p>
            </div>
        </div>
    </div>

    <div id="customizeOverlay" class="customize-overlay hidden">
        <div class="customize-modal">
            <div class="customize-header">
                <div>
                    <h2 id="customizeDrinkTitle">Customize drink</h2>
                    <div id="customizeDrinkPrice" class="muted"></div>
                </div>
                <button class="close-btn" id="closeCustomize" type="button">Close</button>
            </div>

            <div class="customize-layout">
                <div class="customize-preview">
                    <h3 class="section-title" style="margin-top:0;">Preview</h3>
                    <div id="modalPreviewNote" class="muted">Your drink preview updates as you customize.</div>
                </div>

                <div>
                    <div class="option-section">
                        <h3>Sugar level</h3>
                        <div class="choice-grid" id="sugarGrid"></div>
                    </div>

                    <div class="option-section">
                        <h3>Ice level</h3>
                        <div class="choice-grid" id="iceGrid"></div>
                    </div>

                    <div class="option-section">
                        <h3>Add ons</h3>
                        <div class="addon-grid" id="addonGrid"></div>
                    </div>

                    <div class="customize-actions">
                        <button class="cart-btn secondary" id="cancelCustomize" type="button">Cancel</button>
                        <button class="action-btn" id="saveCustomize" type="button">Done</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const menuData = {
            categories: <%- JSON.stringify(categories || {}) %>,
            addons: [
                { id: 101, name: 'Boba', price: 0.75 },
                { id: 102, name: 'Pudding', price: 0.75 },
                { id: 103, name: 'Grass Jelly', price: 0.75 },
                { id: 104, name: 'Lychee Jelly', price: 0.75 },
                { id: 105, name: 'Cheese Foam', price: 1.00 }
            ]
        };

        const drinkStyleMap = <%- JSON.stringify(typeof drinkStyleMap !== 'undefined' ? drinkStyleMap : {}) %>;
        const sugarOptions = ['0%', '25%', '50%', '75%', '100%'];
        const iceOptions = ['No Ice', 'Light Ice', 'Regular Ice', 'Extra Ice'];
        const categoryTabs = document.getElementById('categoryTabs');
        const menuGrid = document.getElementById('menuGrid');
        const addonGrid = document.getElementById('addonGrid');
        const selectedDrinkEl = document.getElementById('selectedDrink');
        const selectedOptionsEl = document.getElementById('selectedOptions');
        const qtyValueEl = document.getElementById('qtyValue');
        const orderListEl = document.getElementById('orderList');
        const orderTotalEl = document.getElementById('orderTotal');
        const customizeOverlay = document.getElementById('customizeOverlay');
        const customizeDrinkTitleEl = document.getElementById('customizeDrinkTitle');
        const customizeDrinkPriceEl = document.getElementById('customizeDrinkPrice');
        const sugarGrid = document.getElementById('sugarGrid');
        const iceGrid = document.getElementById('iceGrid');

        const cubeStackLayers = [
            { id: 'Cube_Topping_Stack_0', scale: 1.0, insertBehind: false },
            { id: 'Cube_Topping_Stack_1', scale: 0.82, insertBehind: true },
            { id: 'Cube_Topping_Stack_2', scale: 0.64, insertBehind: true }
        ];

        let currentCategory = Object.keys(menuData.categories)[0] || null;
        let selectedDrink = null;
        let selectedAddons = [];
        let cubeAddonOrder = [];
        let selectedSugar = '100%';
        let selectedIce = 'Regular Ice';
        let quantity = 1;
        let order = [];
        let drinkSvg = null;
        let customizationDraft = null;

        async function loadDrinkSvg() {
            const mount = document.getElementById('drinkPreviewMount');
            if (!mount) return;

            try {
                const response = await fetch('/images/DrinkFoundation.svg');
                const svgText = await response.text();

                mount.innerHTML = svgText;
                drinkSvg = mount.querySelector('svg');
                setupAddonLayers();
            } catch (err) {
                console.error('Could not load drink SVG:', err);
                mount.innerHTML = '<div class="muted">Could not load drink preview</div>';
            }
        }

        function getGroup(id) {
            if (!drinkSvg) return null;
            return drinkSvg.querySelector(`#${CSS.escape(id)}`);
        }

        function setLayerVisible(groupId, isVisible) {
            const group = getGroup(groupId);
            if (!group) return;
            group.style.display = isVisible ? '' : 'none';
        }

        function setGroupFill(groupId, color) {
            const group = getGroup(groupId);
            if (!group) return;

            const shapes = group.querySelectorAll('path, rect, circle, ellipse, polygon, polyline');
            shapes.forEach((shape) => {
                shape.setAttribute('fill', color);
            });
        }

        function ensureClonedLayer(sourceId, newId, scale = 1, insertBehind = false) {
            if (!drinkSvg) return null;

            const existing = getGroup(newId);
            if (existing) return existing;

            const source = getGroup(sourceId);
            if (!source || !source.parentNode) return null;

            const clone = source.cloneNode(true);
            clone.setAttribute('id', newId);

            const bbox = source.getBBox();
            const centerX = bbox.x + (bbox.width / 2);
            const centerY = bbox.y + (bbox.height / 2);
            const currentTransform = clone.getAttribute('transform') || '';
            const scaleTransform = `translate(${centerX} ${centerY}) scale(${scale}) translate(${-centerX} ${-centerY})`;

            clone.setAttribute('transform', `${currentTransform} ${scaleTransform}`.trim());
            clone.style.display = 'none';

            if (insertBehind) {
                source.parentNode.insertBefore(clone, source);
            } else {
                source.parentNode.appendChild(clone);
            }

            return clone;
        }

        function setupAddonLayers() {
            if (!drinkSvg) return;

            cubeStackLayers.forEach((layer) => {
                ensureClonedLayer('Cube_Topping', layer.id, layer.scale, layer.insertBehind);
            });

            setLayerVisible('Cube_Topping', false);
            resetCubeAddonStack();
        }

        function resetCubeAddonStack() {
            cubeStackLayers.forEach((layer) => setLayerVisible(layer.id, false));
        }

        function clearDrinkPreviewLayers() {
            if (!drinkSvg) return;

            setBobba(false);
            setSeeds(false);
            setSyrup(false);
            setLayerVisible('Cube_Topping', false);
            resetCubeAddonStack();
        }

        function setLidColor(color) {
            setGroupFill('Lid', color);
        }

        function setStrawColor(color) {
            setGroupFill('Straw', color);
        }

        function setLiquidGradient(topColor, midColor, bottomColor) {
            if (!drinkSvg) return;

            const stops = drinkSvg.querySelectorAll('#linear-gradient stop');
            if (stops.length < 3) return;

            stops[0].setAttribute('stop-color', bottomColor);
            stops[1].setAttribute('stop-color', midColor);
            stops[2].setAttribute('stop-color', topColor);
        }

        function setBobba(enabled, color = null) {
            setLayerVisible('Bobba', enabled);
            if (enabled && color) setGroupFill('Bobba', color);
        }

        function setSeeds(enabled, color = null) {
            setLayerVisible('Seeds', enabled);
            if (enabled && color) setGroupFill('Seeds', color);
        }

        function setSyrup(enabled, color = null) {
            setLayerVisible('Syrup', enabled);
            if (enabled && color) setGroupFill('Syrup', color);
        }

        function isCubeAddonName(name) {
            const lower = name.toLowerCase();
            return lower === 'pudding' || lower === 'grass jelly' || lower === 'lychee jelly';
        }

        function getCubeAddonColor(name) {
            const lower = name.toLowerCase();

            if (lower === 'pudding') return '#f7d774';
            if (lower === 'grass jelly') return '#1f1f1f';
            if (lower === 'lychee jelly') return '#f1f5c8';

            return '#d6ffbf';
        }

        function syncCubeAddonOrder() {
            const selectedCubeNames = selectedAddons
                .filter((addon) => isCubeAddonName(addon.name))
                .map((addon) => addon.name);

            cubeAddonOrder = cubeAddonOrder.filter((name) => selectedCubeNames.includes(name));

            selectedCubeNames.forEach((name) => {
                if (!cubeAddonOrder.includes(name)) {
                    cubeAddonOrder.push(name);
                }
            });
        }

        function renderCubeAddonStack() {
            if (!drinkSvg) return;

            setLayerVisible('Cube_Topping', false);
            resetCubeAddonStack();

            cubeAddonOrder.slice(0, cubeStackLayers.length).forEach((addonName, index) => {
                const layerId = cubeStackLayers[index].id;
                const color = getCubeAddonColor(addonName);

                setGroupFill(layerId, color);
                setLayerVisible(layerId, true);
            });
        }

        function applyDrinkStyle(drinkConfig) {
            if (!drinkSvg || !drinkConfig) return;

            if (drinkConfig.lid_color) setLidColor(drinkConfig.lid_color);
            if (drinkConfig.straw_color) setStrawColor(drinkConfig.straw_color);

            if (drinkConfig.liquid_top && drinkConfig.liquid_mid && drinkConfig.liquid_bottom) {
                setLiquidGradient(
                    drinkConfig.liquid_top,
                    drinkConfig.liquid_mid,
                    drinkConfig.liquid_bottom
                );
            }

            setBobba(!!drinkConfig.show_bobba, drinkConfig.bobba_color || null);
            setSeeds(!!drinkConfig.show_seeds, drinkConfig.seeds_color || null);
            setSyrup(!!drinkConfig.show_syrup, drinkConfig.syrup_color || null);
            setLayerVisible('Cube_Topping', false);
            resetCubeAddonStack();
        }

        function updateDrinkPreviewForAddons() {
            if (!drinkSvg) return;

            if (!selectedDrink) {
                clearDrinkPreviewLayers();
                return;
            }

            const baseStyle = drinkStyleMap[selectedDrink.name];
            if (!baseStyle) {
                clearDrinkPreviewLayers();
                return;
            }

            applyDrinkStyle(baseStyle);

            const hasBoba = selectedAddons.some((addon) => addon.name.toLowerCase() === 'boba');
            const hasCheeseFoam = selectedAddons.some((addon) => addon.name.toLowerCase() === 'cheese foam');

            syncCubeAddonOrder();
            renderCubeAddonStack();

            if (hasBoba) {
                setBobba(true, baseStyle.bobba_color || '#2f1707');
            }

            if (hasCheeseFoam) {
                setLiquidGradient('#fff7dc', baseStyle.liquid_mid, baseStyle.liquid_bottom);
            }
        }

        function money(value) {
            return value.toFixed(2);
        }

        function getDefaultCustomization(drink) {
            return {
                drink,
                addons: [],
                cubeAddonOrder: [],
                sugar: '100%',
                ice: 'Regular Ice'
            };
        }

        function openCustomizeModal(drink) {
            customizationDraft = getDefaultCustomization(drink);
            selectedDrink = drink;
            selectedAddons = [...customizationDraft.addons];
            cubeAddonOrder = [...customizationDraft.cubeAddonOrder];
            selectedSugar = customizationDraft.sugar;
            selectedIce = customizationDraft.ice;

            customizeDrinkTitleEl.textContent = `Customize ${drink.name}`;
            customizeDrinkPriceEl.textContent = `$${money(drink.price)}`;
            customizeOverlay.classList.remove('hidden');

            renderSugarOptions();
            renderIceOptions();
            renderAddons();
            renderSelection();
            renderMenu();
            updateDrinkPreviewForAddons();
        }

        function closeCustomizeModal(resetToSavedState = true) {
            customizeOverlay.classList.add('hidden');

            if (resetToSavedState) {
                if (!selectedDrink) {
                    clearDrinkPreviewLayers();
                    return;
                }

                updateDrinkPreviewForAddons();
            }
        }

        function saveCustomization() {
            if (!customizationDraft || !selectedDrink) return;

            customizationDraft.addons = [...selectedAddons];
            customizationDraft.cubeAddonOrder = [...cubeAddonOrder];
            customizationDraft.sugar = selectedSugar;
            customizationDraft.ice = selectedIce;

            closeCustomizeModal(false);
            renderSelection();
            renderMenu();
        }

        function clearCurrentSelection() {
            selectedDrink = null;
            selectedAddons = [];
            cubeAddonOrder = [];
            selectedSugar = '100%';
            selectedIce = 'Regular Ice';
            customizationDraft = null;
            quantity = 1;
            clearDrinkPreviewLayers();
        }

        function renderChoiceButtons(container, options, selectedValue, onSelect) {
            container.innerHTML = '';

            options.forEach((option) => {
                const button = document.createElement('button');
                button.className = 'choice-btn' + (option === selectedValue ? ' selected' : '');
                button.type = 'button';
                button.textContent = option;
                button.onclick = () => onSelect(option);
                container.appendChild(button);
            });
        }

        function renderSugarOptions() {
            renderChoiceButtons(sugarGrid, sugarOptions, selectedSugar, (option) => {
                selectedSugar = option;
                renderSugarOptions();
                renderSelection();
            });
        }

        function renderIceOptions() {
            renderChoiceButtons(iceGrid, iceOptions, selectedIce, (option) => {
                selectedIce = option;
                renderIceOptions();
                renderSelection();
            });
        }

        function renderTabs() {
            categoryTabs.innerHTML = '';

            if (!currentCategory) {
                categoryTabs.innerHTML = '<div class="muted">No categories available</div>';
                return;
            }

            Object.keys(menuData.categories).forEach((category) => {
                const button = document.createElement('button');
                button.className = 'tab-btn' + (category === currentCategory ? ' active' : '');
                button.type = 'button';
                button.textContent = category;
                button.onclick = () => {
                    currentCategory = category;
                    renderTabs();
                    renderMenu();
                };
                categoryTabs.appendChild(button);
            });
        }

        function renderMenu() {
            menuGrid.innerHTML = '';

            if (!currentCategory || !menuData.categories[currentCategory] || menuData.categories[currentCategory].length === 0) {
                menuGrid.innerHTML = '<div class="muted">No items in this category</div>';
                return;
            }

            menuData.categories[currentCategory].forEach((item) => {
                const isSelected = selectedDrink && selectedDrink.id === item.id;
                const button = document.createElement('button');
                button.className = 'item-btn' + (isSelected ? ' selected' : '');
                button.type = 'button';
                button.innerHTML = `<h3>${item.name}</h3><p>$${money(item.price)}</p>`;
                button.onclick = () => {
                    openCustomizeModal(item);
                };
                menuGrid.appendChild(button);
            });
        }

        function renderAddons() {
            addonGrid.innerHTML = '';

            menuData.addons.forEach((addon) => {
                const button = document.createElement('button');
                button.className = 'addon-btn' + (selectedAddons.some((a) => a.id === addon.id) ? ' selected' : '');
                button.type = 'button';
                button.textContent = `${addon.name} +$${money(addon.price)}`;
                button.onclick = () => {
                    const exists = selectedAddons.some((a) => a.id === addon.id);

                    if (exists) {
                        selectedAddons = selectedAddons.filter((a) => a.id !== addon.id);
                    } else {
                        selectedAddons.push(addon);
                    }

                    renderAddons();
                    renderSelection();
                    updateDrinkPreviewForAddons();
                };
                addonGrid.appendChild(button);
            });
        }

        function renderSelection() {
            if (!selectedDrink) {
                selectedDrinkEl.textContent = 'No drink selected yet';
            } else {
                selectedDrinkEl.textContent = `${selectedDrink.name}  $${money(selectedDrink.price)}`;
            }

            const optionParts = [];

            if (selectedDrink) {
                optionParts.push(`Sugar: ${selectedSugar}`);
                optionParts.push(`Ice: ${selectedIce}`);
            }

            if (selectedAddons.length > 0) {
                optionParts.push('Add ons: ' + selectedAddons.map((addon) => `${addon.name} +$${money(addon.price)}`).join(', '));
            }

            selectedOptionsEl.textContent = optionParts.length
                ? optionParts.join(' | ')
                : 'Choose a drink to customize sugar, ice, and add ons';

            qtyValueEl.textContent = quantity;
        }

        function renderOrder() {
            if (order.length === 0) {
                orderListEl.innerHTML = '<div class="muted">Your order is empty</div>';
                orderTotalEl.textContent = '0.00';
                return;
            }

            orderListEl.innerHTML = '';
            let total = 0;

            order.forEach((item, index) => {
                total += item.total;

                const div = document.createElement('div');
                div.className = 'order-item';
                div.innerHTML = `
                    <h3>${item.quantity} x ${item.name}</h3>
                    <div>Sugar: ${item.sugar} | Ice: ${item.ice}</div>
                    <div>${item.addons.length ? 'Add ons: ' + item.addons.map((addon) => addon.name).join(', ') : 'No add ons'}</div>
                    <div style="margin-top:8px;"><strong>$${money(item.total)}</strong></div>
                    <button class="cart-btn danger" type="button" style="margin-top:10px;" onclick="removeOrderItem(${index})">Remove</button>
                `;
                orderListEl.appendChild(div);
            });

            orderTotalEl.textContent = money(total);
        }

        function addToOrder() {
            if (!selectedDrink) {
                alert('Pick a drink first');
                return;
            }

            const addonTotal = selectedAddons.reduce((sum, addon) => sum + addon.price, 0);
            const total = (selectedDrink.price + addonTotal) * quantity;

            order.push({
                drinkId: selectedDrink.id,
                name: selectedDrink.name,
                addons: [...selectedAddons],
                sugar: selectedSugar,
                ice: selectedIce,
                quantity,
                total
            });

            clearCurrentSelection();
            closeCustomizeModal(false);
            renderMenu();
            renderAddons();
            renderSelection();
            renderOrder();
        }

        function removeOrderItem(index) {
            order.splice(index, 1);
            renderOrder();
        }

        async function checkoutOrder() {
            if (order.length === 0) {
                alert('Order is empty');
                return;
            }

            const payload = { order };

            try {
                const res = await fetch('/submitOrder', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                const data = await res.json();

                if (data.success) {
                    alert('Order submitted successfully!');
                    order = [];
                    renderOrder();
                } else {
                    alert('Order failed');
                }
            } catch (err) {
                console.error(err);
                alert('Server error');
            }
        }

        async function initializeKiosk() {
            await loadDrinkSvg();

            if (Object.keys(menuData.categories).length > 0) {
                renderTabs();
                renderMenu();
                renderAddons();
                renderSelection();
                renderOrder();

                const firstCategory = Object.keys(menuData.categories)[0];
                const firstDrink = firstCategory && menuData.categories[firstCategory]?.[0];

                if (firstDrink && drinkStyleMap[firstDrink.name]) {
                    applyDrinkStyle(drinkStyleMap[firstDrink.name]);
                }
            } else {
                document.querySelector('.section-title').textContent = 'No menu items available';
            }
        }

        window.removeOrderItem = removeOrderItem;

        document.getElementById('minusQty').onclick = () => {
            if (quantity > 1) {
                quantity -= 1;
                renderSelection();
            }
        };

        document.getElementById('plusQty').onclick = () => {
            quantity += 1;
            renderSelection();
        };

        document.getElementById('addToOrder').onclick = addToOrder;
        document.getElementById('clearOrder').onclick = () => {
            order = [];
            renderOrder();
        };
        document.getElementById('checkoutOrder').onclick = checkoutOrder;
        document.getElementById('closeCustomize').onclick = () => closeCustomizeModal();
        document.getElementById('cancelCustomize').onclick = () => closeCustomizeModal();
        document.getElementById('saveCustomize').onclick = saveCustomization;

        initializeKiosk();
    </script>
</body>
</html>
