<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kiosk</title>
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background: #f3f4f6;
            color: #111827;
        }
        .page {
            max-width: 1450px;
            margin: 0 auto;
            padding: 24px;
        }
        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        .topbar h1 {
            margin: 0;
            font-size: 2rem;
        }
        .topbar a {
            text-decoration: none;
            background: #111827;
            color: white;
            padding: 10px 14px;
            border-radius: 10px;
        }
        .layout {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 24px;
            align-items: start;
        }
        .panel {
            background: white;
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 10px 28px rgba(0,0,0,0.08);
        }
        .section-title {
            margin: 0 0 14px 0;
            font-size: 1.35rem;
        }
        .category-tabs {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 18px;
        }
        .tab-btn {
            border: none;
            border-radius: 999px;
            padding: 12px 18px;
            font-weight: 700;
            cursor: pointer;
            background: #e5e7eb;
            color: #111827;
        }
        .tab-btn.active {
            background: #2563eb;
            color: white;
        }
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
            gap: 14px;
        }
        .item-btn {
            border: 2px solid #d1d5db;
            border-radius: 14px;
            background: #f9fafb;
            padding: 18px;
            text-align: left;
            cursor: pointer;
            min-height: 108px;
        }
        .item-btn:hover {
            border-color: #2563eb;
        }
        .item-btn h3 {
            margin: 0 0 8px 0;
            font-size: 1.1rem;
        }
        .item-btn p {
            margin: 0;
            color: #4b5563;
            font-size: 0.95rem;
        }
        .addons {
            margin-top: 22px;
        }
        .addon-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
        }
        .addon-btn {
            border: 2px solid #d1d5db;
            border-radius: 12px;
            background: white;
            padding: 12px;
            cursor: pointer;
            font-weight: 700;
        }
        .addon-btn.selected {
            background: #dbeafe;
            border-color: #2563eb;
        }
        .selected-box {
            margin-top: 20px;
            padding: 16px;
            border-radius: 14px;
            background: #eff6ff;
            border: 1px solid #bfdbfe;
        }
        .selected-box h3 {
            margin-top: 0;
        }
        .qty-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 12px;
            flex-wrap: wrap;
        }
        .qty-btn, .action-btn, .cart-btn {
            border: none;
            border-radius: 10px;
            padding: 10px 14px;
            font-weight: 700;
            cursor: pointer;
        }
        .qty-btn { background: #d1d5db; }
        .action-btn { background: #2563eb; color: white; }
        .cart-btn.secondary { background: #6b7280; color: white; }
        .cart-btn.danger { background: #dc2626; color: white; }
        .order-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin: 16px 0;
        }
        .order-item {
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 14px;
            background: #f9fafb;
        }
        .order-item h3 {
            margin: 0 0 6px 0;
        }
        .total {
            font-size: 1.35rem;
            font-weight: 800;
            margin: 18px 0;
        }
        .muted {
            color: #6b7280;
        }
        .cart-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        .hidden {
            display: none;
        }
        @media (max-width: 960px) {
            .layout { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="topbar">
            <div>
                <h1>Self Service Kiosk</h1>
                <div class="muted">Database-connected menu items and orders</div>
                <button class="translateButton" id="translateToggle" type="button">ES</button>
            </div>
        </div>

        <div class="layout">
            <div class="panel">
                <h2 class="section-title">Choose a category</h2>
                <div class="category-tabs" id="categoryTabs"></div>
                

                <h2 class="section-title">Menu items</h2>
                <div class="menu-grid" id="menuGrid"></div>

                <div class="addons">
                    <h2 class="section-title">Add ons</h2>
                    <div class="addon-grid" id="addonGrid"></div>
                </div>

                <div class="selected-box">
                    <h3>Current selection</h3>
                    <div id="selectedDrink" class="muted">No drink selected yet</div>
                    <div id="selectedAddons" class="muted" style="margin-top:8px;">No add ons selected</div>

                    <div class="qty-row">
                        <span>Quantity</span>
                        <button class="qty-btn" id="minusQty" type="button">-</button>
                        <strong id="qtyValue">1</strong>
                        <button class="qty-btn" id="plusQty" type="button">+</button>
                        <button class="action-btn" id="addToOrder" type="button">Add to order</button>
                    </div>
                </div>
            </div>

            <div class="panel">
                <h2 class="section-title">Your order</h2>
                <div id="orderList" class="order-list">
                    <div class="muted">Your order is empty</div>
                </div>
                <div class="total">Total $<span id="orderTotal">0.00</span></div>
                <div class="cart-actions">
                    <button class="cart-btn secondary" id="clearOrder" type="button">Clear order</button>
                    <button class="cart-btn" id="checkoutOrder" type="button">Checkout</button>
                </div>
                <p class="muted" style="margin-top:14px;">Powered by database integration. Menu items are fetched from the server.</p>
            </div>
        </div>
    </div>

    <script>
        // Data from server (database)
        const menuData = {
            categories: <%- JSON.stringify(categories || {}) %>,
            addons: [
                { id: 101, name: 'Boba', price: 0.75 },
                { id: 102, name: 'Pudding', price: 0.75 },
                { id: 103, name: 'Grass Jelly', price: 0.75 },
                { id: 104, name: 'Lychee Jelly', price: 0.75 },
                { id: 105, name: 'Cheese Foam', price: 1.00 }
            ]
        };

        const categoryTabs = document.getElementById('categoryTabs');
        const menuGrid = document.getElementById('menuGrid');
        const addonGrid = document.getElementById('addonGrid');
        const selectedDrinkEl = document.getElementById('selectedDrink');
        const selectedAddonsEl = document.getElementById('selectedAddons');
        const qtyValueEl = document.getElementById('qtyValue');
        const orderListEl = document.getElementById('orderList');
        const orderTotalEl = document.getElementById('orderTotal');

        let currentCategory = Object.keys(menuData.categories)[0] || null;
        let selectedDrink = null;
        let selectedAddons = [];
        let quantity = 1;
        let order = [];

        function money(value) {
            return value.toFixed(2);
        }

        function renderTabs() {
            categoryTabs.innerHTML = '';
            if (!currentCategory) {
                categoryTabs.innerHTML = '<div class="muted">No categories available</div>';
                return;
            }
            Object.keys(menuData.categories).forEach((category) => {
                const button = document.createElement('button');
                button.className = 'tab-btn' + (category === currentCategory ? ' active' : '');
                button.textContent = translateName(category);
                button.type = 'button';
                button.onclick = () => {
                    currentCategory = category;
                    renderTabs();
                    renderMenu();
                };
                categoryTabs.appendChild(button);
            });
        }

        function renderMenu() {
            menuGrid.innerHTML = '';
            if (!currentCategory || !menuData.categories[currentCategory] || menuData.categories[currentCategory].length === 0) {
                menuGrid.innerHTML = '<div class="muted">No items in this category</div>';
                return;
            }
            menuData.categories[currentCategory].forEach((item) => {
                const button = document.createElement('button');
                button.className = 'item-btn';
                button.type = 'button';
                button.innerHTML = `<h3>${translateName(item.name)}</h3><p>$${money(item.price)}</p>`;
                button.onclick = () => {
                    selectedDrink = item;
                    renderSelection();
                };
                menuGrid.appendChild(button);
            });
        }

        function renderAddons() {
            addonGrid.innerHTML = '';
            menuData.addons.forEach((addon) => {
                const button = document.createElement('button');
                button.className = 'addon-btn' + (selectedAddons.some((a) => a.id === addon.id) ? ' selected' : '');
                button.type = 'button';
                button.textContent = `${translateName(addon.name)} +$${money(addon.price)}`;
                button.onclick = () => {
                    const exists = selectedAddons.some((a) => a.id === addon.id);
                    if (exists) {
                        selectedAddons = selectedAddons.filter((a) => a.id !== addon.id);
                    } else {
                        selectedAddons.push(addon);
                    }
                    renderAddons();
                    renderSelection();
                };
                addonGrid.appendChild(button);
            });
        }

        function renderSelection() {
            if (!selectedDrink) {
                selectedDrinkEl.textContent = currentLang === 'es' ? 'Ninguna bebida seleccionada' : 'No drink selected yet';
            } else {
                selectedDrinkEl.textContent = `${translateName(selectedDrink.name)}  $${money(selectedDrink.price)}`;
            }

            if (selectedAddons.length === 0) {
                selectedAddonsEl.textContent = currentLang === 'es' ? 'No se seleccionaron extras' : 'No add ons selected';
            } else {
                selectedAddonsEl.textContent =
                    (currentLang === 'es' ? 'Extras: ' : 'Add ons: ') +
                    selectedAddons.map((a) => `${translateName(a.name)} +$${money(a.price)}`).join(', ');
            }

            qtyValueEl.textContent = quantity;
        }

        function renderOrder() {
            if (order.length === 0) {
                orderListEl.innerHTML = `<div class="muted">${currentLang === 'es' ? 'Tu pedido está vacío' : 'Your order is empty'}</div>`;
                orderTotalEl.textContent = '0.00';
                return;
            }

            orderListEl.innerHTML = '';
            let total = 0;

            order.forEach((item, index) => {
                total += item.total;
                const div = document.createElement('div');
                div.className = 'order-item';
                div.innerHTML = `
                    <h3>${item.quantity} x ${translateName(item.name)}</h3>
                    <div>${
                        item.addons.length
                            ? (currentLang === 'es' ? 'Extras: ' : 'Add ons: ') + item.addons.map((a) => translateName(a.name)).join(', ')
                            : (currentLang === 'es' ? 'Sin extras' : 'No add ons')
                    }</div>
                    <div style="margin-top:8px;"><strong>$${money(item.total)}</strong></div>
                    <button class="cart-btn danger" type="button" style="margin-top:10px;" onclick="removeOrderItem(${index})">Remove</button>
                `;
                orderListEl.appendChild(div);
            });

            orderTotalEl.textContent = money(total);
        }

        function addToOrder() {
            if (!selectedDrink) {
                alert('Pick a drink first');
                return;
            }

            const addonTotal = selectedAddons.reduce((sum, addon) => sum + addon.price, 0);
            const total = (selectedDrink.price + addonTotal) * quantity;

            order.push({
                drinkId: selectedDrink.id,
                name: selectedDrink.name,
                addons: [...selectedAddons],
                quantity,
                total
            });

            selectedDrink = null;
            selectedAddons = [];
            quantity = 1;
            renderAddons();
            renderSelection();
            renderOrder();
        }

        function removeOrderItem(index) {
            order.splice(index, 1);
            renderOrder();
        }
        window.removeOrderItem = removeOrderItem;

        document.getElementById('minusQty').onclick = () => {
            if (quantity > 1) {
                quantity -= 1;
                renderSelection();
            }
        };

        document.getElementById('plusQty').onclick = () => {
            quantity += 1;
            renderSelection();
        };

        document.getElementById('addToOrder').onclick = addToOrder;

        document.getElementById('clearOrder').onclick = () => {
            order = [];
            renderOrder();
        };

            console.log('Order being processed:', order);
        document.getElementById('checkoutOrder').onclick = async () => {
    if (order.length === 0) {
        alert('Order is empty');
        return;
    }

    console.log('Order being processed:', order);

    const payload = { order };

    try {
        const res = await fetch('/submitOrder', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
        });

        const data = await res.json();

        if (data.success) {
            alert('Order submitted successfully!');
            order = [];
            renderOrder();
        } else {
            alert('Order failed');
        }

    } catch (err) {
        console.error(err);
        alert('Server error');
    }
};


    

    let currentLang = "en";

    document.getElementById("translateToggle").onclick = async () => {
    if (currentLang === "en") {
        setLanguage("es");
        currentLang = "es";
        document.getElementById("translateToggle").innerText = "EN";
    } else {
        setLanguage("en");
        currentLang = "en";
        document.getElementById("translateToggle").innerText = "ES";
    }

    renderTabs();
    renderMenu();
    renderAddons();
    renderSelection();
    renderOrder();
};
const translations = {
    en: {
        title: "Self Service Kiosk",
        chooseCategory: "Choose a category",
        menuItems: "Menu items",
        addOns: "Add ons",
        currentSelection: "Current selection",
        noDrink: "No drink selected yet",
        noAddons: "No add ons selected",
        quantity: "Quantity",
        addToOrder: "Add to order",
        yourOrder: "Your order",
        emptyOrder: "Your order is empty",
        clearOrder: "Clear order",
        checkout: "Checkout"
    },
    es: {
        title: "Quiosco de Autoservicio",
        chooseCategory: "Elige una categoría",
        menuItems: "Artículos del menú",
        addOns: "Extras",
        currentSelection: "Selección actual",
        noDrink: "Ninguna bebida seleccionada",
        noAddons: "No se seleccionaron extras",
        quantity: "Cantidad",
        addToOrder: "Agregar al pedido",
        yourOrder: "Tu pedido",
        emptyOrder: "Tu pedido está vacío",
        clearOrder: "Vaciar pedido",
        checkout: "Pagar"
    }
};
const itemTranslations = {
    en: {
        "Milk Tea": "Milk Tea",
        "Tea": "Tea",
        "Fruit Tea": "Fruit Tea",
        "Smoothie": "Smoothie",
        "Specialty": "Specialty",
        "Energy": "Energy",
        "Sour": "Sour",
        "Matcha": "Matcha",
        "ADDON": "ADDON",
        "SEASONAL": "SEASONAL",

        "Boba": "Boba",
        "Pudding": "Pudding",
        "Grass Jelly": "Grass Jelly",
        "Lychee Jelly": "Lychee Jelly",
        "Cheese Foam": "Cheese Foam",

        "Lava Flow": "Lava Flow",
        "Misty Milk": "Misty Milk",
        "Skilly n Duff": "Skilly n Duff",
        "Coal Chocolate": "Coal Chocolate",
        "Flounder Creme Brulee": "Flounder Creme Brulee",
        "Mola Mola Matcha": "Mola Mola Matcha",
        "Black Sea": "Black Sea"
    },
    es: {
        "Milk Tea": "Té con leche",
        "Tea": "Té",
        "Fruit Tea": "Té de frutas",
        "Smoothie": "Batido",
        "Specialty": "Especialidad",
        "Energy": "Energía",
        "Sour": "Ácido",
        "Matcha": "Matcha",
        "ADDON": "EXTRAS",
        "SEASONAL": "TEMPORADA",

        "Boba": "Boba",
        "Pudding": "Pudín",
        "Grass Jelly": "Gelatina de hierbas",
        "Lychee Jelly": "Gelatina de lichi",
        "Cheese Foam": "Espuma de queso",

        "Lava Flow": "Flujo de lava",
        "Misty Milk": "Leche brumosa",
        "Skilly n Duff": "Skilly n Duff",
        "Coal Chocolate": "Chocolate carbón",
        "Flounder Creme Brulee": "Crema brûlée Flounder",
        "Mola Mola Matcha": "Matcha Mola Mola",
        "Black Sea": "Mar Negro"
    }
};

function translateName(name) {
    return itemTranslations[currentLang]?.[name] || name;
}

function setLanguage(lang) {
    document.querySelector(".topbar h1").innerText = translations[lang].title;
    document.querySelectorAll(".section-title")[0].innerText = translations[lang].chooseCategory;
    document.querySelectorAll(".section-title")[1].innerText = translations[lang].menuItems;
    document.querySelectorAll(".section-title")[2].innerText = translations[lang].addOns;
    document.querySelector(".selected-box h3").innerText = translations[lang].currentSelection;

    if (!selectedDrink) {
        selectedDrinkEl.innerText = translations[lang].noDrink;
    }

    if (selectedAddons.length === 0) {
        selectedAddonsEl.innerText = translations[lang].noAddons;
    }

    document.querySelector(".qty-row span").innerText = translations[lang].quantity;
    document.getElementById("addToOrder").innerText = translations[lang].addToOrder;

    document.querySelectorAll(".section-title")[3].innerText = translations[lang].yourOrder;

    if (order.length === 0) {
        orderListEl.innerHTML = `<div class="muted">${translations[lang].emptyOrder}</div>`;
    }

    document.getElementById("clearOrder").innerText = translations[lang].clearOrder;
    document.getElementById("checkoutOrder").innerText = translations[lang].checkout;
}
        // Initialize UI
        if (Object.keys(menuData.categories).length > 0) {
            renderTabs();
            renderMenu();
            renderAddons();
            renderSelection();
            renderOrder();
        } else {
            document.querySelector('.section-title').textContent = 'No menu items available';
        }
    </script>
</body>
</html>
