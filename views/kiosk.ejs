<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kiosk</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/kiosk.css">
</head>
<body>
    <div class="page">
        <div class="topbar">
            <div class="topbar-brand">
                <img src="/images/favicon.ico" alt="FSH Boba icon" class="topbar-logo">
                <h1>FSH Boba - Self Service Kiosk</h1>
            </div>
            <div id="google_translate_element">
                <button onclick="toggleHighContrast()" id="highContrastBtn" type="button">High Contrast</button>
                <button onclick="toggleLowContrast()" id="lowContrastBtn" type="button">Low Contrast</button>
                <button onclick="toggleScreenMagnifier()" type="button">Toggle Magnifier</button>
                <button id="fontToggle" onclick="toggleFontSize()" type="button">Toggle Font Size</button>
            </div>
            <div id="screenMagnifier">
                <div id="screenMagnifierContent"></div>
            </div>
        </div>

        <div class="layout">
            <div class="panel main-panel">
                <h2 class="section-title">Choose a category</h2>
                <div class="category-tabs" id="categoryTabs"></div>

                <h2 class="section-title">Menu items</h2>
                <div class="menu-grid" id="menuGrid"></div>

            </div>

            <div class="panel order-panel">
                <h2 class="section-title">My order</h2>
                <div id="orderList" class="order-list">
                    <div class="muted">Your order is empty</div>
                </div>
                <div class="total">Total $<span id="orderTotal">0.00</span></div>
                <div class="cart-actions">
                    <button class="cart-btn secondary" id="clearOrder" type="button">Clear order</button>
                    <button class="cart-btn" id="checkoutOrder" type="button">Checkout</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Order confirmation overlay -->
    <div id="resultOverlay" class="result-overlay hidden" aria-live="polite">
        <div id="resultCard" class="result-card">
            <div class="result-badge" id="resultBadge"></div>
            <h2 id="resultTitle">Order confirmed</h2>
            <p id="resultMessage" class="result-message"></p>
            <div id="resultTicket" class="result-ticket hidden"></div>
            <button class="action-btn result-ok-btn" id="resultOkBtn" type="button">OK</button>
        </div>
    </div>

    <div id="customizeOverlay" class="customize-overlay hidden">
        <div class="customize-modal">
            <div class="customize-header">
                <div>
                    <h2 id="customizeDrinkTitle">Customize drink</h2>
                    <div id="customizeDrinkPrice" class="muted"></div>
                </div>
                <button class="close-btn" id="closeCustomize" type="button">Close</button>
            </div>

            <div class="customize-layout">
                <div class="customize-preview">
                    <div class="modal-drink-preview-mount">
                        <div class="modal-drink-preview-frame">
                            <div id="modalDrinkPreviewMount"></div>
                            <div id="previewWaveOverlay" class="preview-wave-overlay"></div>
                        </div>
                    </div>
                </div>

                <div>
                    <div class="option-section">
                        <h3>Sugar level</h3>
                        <div class="choice-grid" id="sugarGrid"></div>
                    </div>

                    <div class="option-section">
                        <h3>Ice level</h3>
                        <div class="choice-grid" id="iceGrid"></div>
                    </div>

                    <div class="option-section">
                        <h3>Add ons</h3>
                        <div id="addonCategoryTabs" class="addon-category-tabs"></div>
                        <div class="addon-grid" id="addonGrid"></div>
                    </div>

                    <div class="customize-actions">
                        <div class="qty-row modal-qty-row">
                            <span>Quantity</span>
                            <button class="qty-btn" id="minusQty" type="button">-</button>
                            <strong id="qtyValue">1</strong>
                            <button class="qty-btn" id="plusQty" type="button">+</button>
                        </div>
                        <button class="cart-btn secondary" id="cancelCustomize" type="button">Cancel</button>
                        <button class="action-btn" id="saveCustomize" type="button">Done</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        window.kioskPageData = {
            menuData: {
                categories: <%- JSON.stringify(categories || {}) %>,
                addons: <%- JSON.stringify(addons || []) %>
            },
            drinkStyleMap: <%- JSON.stringify(typeof drinkStyleMap !== 'undefined' ? drinkStyleMap : {}) %>
        };
    </script>
    <section class="weather-widget" aria-label="Current weather in College Station">
        <h3><%= weather.location %></h3>
        <% if (weather.available) { %>
            <div class="weather-temp"><%= weather.temperature %>F</div>
            <p class="weather-meta"><%= weather.summary %></p>
            <p class="weather-meta">Feels like <%= weather.feelsLike %>F</p>
            <p class="weather-meta">Wind <%= weather.windSpeed %> mph</p>
        <% } else { %>
            <p class="weather-meta"><%= weather.summary %></p>
        <% } %>
    </section>
    <script src="/js/kiosk.js"></script>
    <script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
</body>
</html>
