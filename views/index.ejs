<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Boba Shop System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Nunito', Arial, Helvetica, sans-serif;
            background:
                radial-gradient(circle at top left, rgba(255, 244, 208, 0.8), transparent 30%),
                radial-gradient(circle at right center, rgba(255, 214, 194, 0.75), transparent 28%),
                #ccf8ff;
            color: #111827;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px 20px;
        }

        .landing-shell {
            width: 100%;
            max-width: 980px;
        }

        .landing-card {
            background: rgba(238, 252, 255, 0.92);
            border: 1px solid rgba(255, 255, 255, 0.75);
            border-radius: 30px;
            box-shadow: 0 18px 48px rgba(72, 119, 140, 0.16);
            padding: 44px 36px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .landing-card::before,
        .landing-card::after {
            content: '';
            position: absolute;
            border-radius: 999px;
            opacity: 0.8;
            pointer-events: none;
        }

        .landing-card::before {
            width: 180px;
            height: 180px;
            background: rgba(255, 214, 194, 0.45);
            top: -60px;
            right: -40px;
        }

        .landing-card::after {
            width: 140px;
            height: 140px;
            background: rgba(255, 243, 179, 0.42);
            bottom: -40px;
            left: -30px;
        }

        .eyebrow {
            display: inline-block;
            margin-bottom: 14px;
            padding: 8px 16px;
            border-radius: 999px;
            background: #ffe8de;
            color: #7c4a35;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            font-size: 0.82rem;
            position: relative;
            z-index: 1;
        }

        h1 {
            margin: 0;
            font-family: 'Fredoka', 'Nunito', Arial, Helvetica, sans-serif;
            font-size: clamp(2.8rem, 6vw, 4.7rem);
            line-height: 0.98;
            font-weight: 700;
            position: relative;
            z-index: 1;
        }

        .subtitle {
            max-width: 620px;
            margin: 18px auto 36px;
            font-size: 1.15rem;
            line-height: 1.6;
            color: #4b5563;
            position: relative;
            z-index: 1;
        }

        .portal-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
            position: relative;
            z-index: 1;
        }

        .portal-button {
            border: 2px solid rgba(17, 24, 39, 0.08);
            border-radius: 24px;
            padding: 22px 20px;
            text-decoration: none;
            color: #111827;
            text-align: left;
            box-shadow: 0 10px 24px rgba(17, 24, 39, 0.08);
            transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
        }

        .portal-button:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 30px rgba(17, 24, 39, 0.12);
            border-color: rgba(37, 99, 235, 0.35);
        }

        .portal-button h2 {
            margin: 0 0 8px 0;
            font-family: 'Fredoka', 'Nunito', Arial, Helvetica, sans-serif;
            font-size: 1.65rem;
            font-weight: 600;
        }

        .portal-button p {
            margin: 0;
            font-size: 1rem;
            line-height: 1.5;
            color: #374151;
        }

        .cashier {
            background: #f5e3ef;
        }

        .manager {
            background: #e0ecff;
        }

        .kiosk {
            background: #ffe0cf;
        }

        @media (max-width: 860px) {
            .portal-grid {
                grid-template-columns: 1fr;
            }

            .landing-card {
                padding: 34px 22px;
                border-radius: 24px;
            }

            .portal-button {
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <main class="landing-shell">
        <section class="landing-card">
            <h1>FSH Boba</h1>

            <div class="portal-grid">
                <a class="portal-button cashier" href="/loginCashier">
                    <h2>Cashier Login</h2>
                    <p>Open the point-of-sale flow for team members handling orders in person.</p>
                </a>

                <a class="portal-button manager" href="/loginManager">
                    <h2>Manager Login</h2>
                    <p>Head to reports, employees, inventory, and the rest of the admin tools.</p>
                </a>

                <a class="portal-button kiosk" href="/kiosk">
                    <h2>Self-Serving Kiosk</h2>
                    <p>Launch the customer-facing ordering experience.</p>
                </a>
            </div>
        </section>
    </main>
</body>
</html>
