<!DOCTYPE html>
<html>
<head>
    <title>Boba POS</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            margin-top: 100px;
            background-color: #f4f4f4;
        }

        h1 {
            margin-bottom: 40px;
        }

        .btn {
            display: block;
            width: 200px;
            margin: 15px auto;
            padding: 15px;
            font-size: 16px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }

        .cashier { background-color: #4CAF50; color: white; }
        .manager { background-color: #2196F3; color: white; }
        .kiosk   { background-color: #ff9800; color: white; }

        .btn:hover {
            opacity: 0.85;
        }
    </style>
</head>

<body>

<h1>Boba Shop System</h1>

<button class="btn cashier" onclick="window.location.href='/login?role=cashier'">
  Cashier Login
</button>

<button class="btn manager" onclick="window.location.href='/login?role=manager'">
  Manager Login
</button>

<button class="btn kiosk" onclick="window.location.href='/kiosk'">
  Kiosk (Customer)
</button>

</body>
</html>