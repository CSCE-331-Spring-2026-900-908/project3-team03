<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cashier Interface</title>
    <style>
        table { border-collapse: collapse; width: 50%; margin: 16px auto; }
        th, td { border: 1px solid #aaa; padding: 8px; text-align: left; }
        th { background: #eee; }
    </style>
</head>
<body>
    <header></header>

    <nav>
        <ul>
            <li>Milk Teas</li>

            <li>Matchas</li>

            <li>Seasonal</li>
        </ul>
    </nav>

    <aside>
        <h1>Current Order</h1>

        <article class="order_item">
            <h1>Chard Shore</h1>

            <ul>
                <li>Sugar: 75%</li>

                <li>Ice: Extra</li>

                <li>Addons: extra boba, eye of newt</li>
            </ul>

            <button>Remove</button>
            <button><a href="/cashiercustomize">Modify</a></button>
        </article>

        <article class="order_item">
            <h1>Chard Shore</h1>

            <ul>
                <li>Sugar: 50%</li>

                <li>Ice: Normal</li>

                <li>Addons: none</li>
            </ul>

            <button>Remove</button>
            <button><a href="/cashiercustomize">Modify</a></button>
        </article>

        <article class="order_item">
            <h1>Chard Shore</h1>

            <ul>
                <li>Sugar: 75%</li>

                <li>Ice: Less</li>

                <li>Addons: grass jelly</li>
            </ul>

            <button>Remove</button>
            <button><a href="/cashiercustomize">Modify</a></button>
        </article>

        <button>Cancel Order</button>
        <button><a href="/cashiercheckout">Checkout</a></button>
    </aside>

    <div>
        <button><a href="/cashiercustomize">Placeholder Drink</a></button>
        <button><a href="/cashiercustomize">Placeholder Drink</a></button>
        <button><a href="/cashiercustomize">Placeholder Drink</a></button>
        <button><a href="/cashiercustomize">Placeholder Drink</a></button>
        <button><a href="/cashiercustomize">Placeholder Drink</a></button>
        <button><a href="/cashiercustomize">Placeholder Drink</a></button>
        <button><a href="/cashiercustomize">Placeholder Drink</a></button>
        <button><a href="/cashiercustomize">Placeholder Drink</a></button>
        <button><a href="/cashiercustomize">Placeholder Drink</a></button>
        <button><a href="/cashiercustomize">Placeholder Drink</a></button>
        <button><a href="/cashiercustomize">Placeholder Drink</a></button>
        <button><a href="/cashiercustomize">Placeholder Drink</a></button>
        <button><a href="/cashiercustomize">Placeholder Drink</a></button>
        <button><a href="/cashiercustomize">Placeholder Drink</a></button>
    </div>


    <h1>Cashier Interface</h1>
    <p>Welcome, Cashier! Manage orders here.</p>
    
    <h2>All Cashiers</h2>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Role</th>
            </tr>
        </thead>
        <tbody>
        <% if (employees && employees.length) { %>
            <% employees.forEach(employee => { %>
            <tr>
                <td><%= employee.employee_id %></td>
                <td><%= employee.first_name %> <%= employee.last_name %></td>
                <td><%= employee.role %></td>
            </tr>
            <% }) %>
        <% } else { %>
            <tr><td colspan="3">No cashiers found</td></tr>
        <% } %>
        </tbody>
    </table>
    
    <!-- Add cashier functionality here -->
    <a href="/logout">Logout</a>
</body>
</html>