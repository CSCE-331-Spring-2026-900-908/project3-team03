<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout</title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
            background: #f1f1f1;
        }
        header {
            font-size: 28px;
            font-weight: bold;
            margin-bottom: 20px;
            color: #333;
        }
        .cart-items {
            background: white;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 20px;
        }
        .order-item {
            border: 1px solid #ddd;
            padding: 15px;
            margin-bottom: 15px;
            border-radius: 8px;
            background: #fafafa;
        }
        .order-item h2 {
            margin: 0 0 10px 0;
            color: #333;
        }
        .order-item ul {
            list-style: none;
            padding: 0;
            margin: 10px 0;
        }
        .order-item li {
            padding: 5px 0;
            color: #666;
        }
        .item-price {
            font-weight: bold;
            color: #2c3e50;
            font-size: 16px;
            margin-top: 10px;
        }
        .summary {
            background: white;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            text-align: right;
        }
        .summary h3 {
            margin: 10px 0;
            color: #333;
        }
        .total {
            font-size: 24px;
            font-weight: bold;
            color: rgb(62, 62, 113);
            border-top: 2px solid #ddd;
            padding-top: 10px;
        }
        footer {
            display: flex;
            gap: 10px;
            justify-content: center;
        }
        button {
            height: 50px;
            padding: 0px;
            border-radius: 25px;
            border: none;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s;
        }
        .cancel-btn {
            background: #f1f1f1;
            color: #333;
        }

        .cancel-btn a {
            display: block;
            text-decoration: none;
            height: 30px;
            width: 150px;
            padding: 17px;
        }

        .cancel-btn:hover {
            background: #ddd;
        }
        .confirm-btn {
            background: rgb(62, 62, 113);
            color: white;
        }
        .confirm-btn:hover {
            background: rgb(114, 122, 154);
        }
        .confirm-btn a {
            display: block;
            text-decoration: none;
            color: white;
            height: 30px;
            width: 150px;
            padding: 17px;
            text-decoration: none;
            color: white;
        }
        .empty-message {
            text-align: center;
            color: #999;
            padding: 20px;
            font-size: 16px;
        }
        .status-message {
            background: #fff3cd;
            border: 1px solid #ffc107;
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 15px;
            color: #856404;
        }
    </style>
</head>
<body>
    <header>Checkout</header>
    
    <% if (statusMessage) { %>
        <div class="status-message"><%= statusMessage %></div>
    <% } %>
    
    <div class="cart-items">
        <% if (drinks && drinks.length > 0) { %>
            <% drinks.forEach((drink, idx) => { %>
                <article class="order-item">
                    <h2><%= drink.menuItemName || 'Item ' + (idx+1) %></h2>
                    <ul>
                        <li><strong>Sugar:</strong> <%= drink.sugarAmount || 'N/A' %></li>
                        <li><strong>Ice:</strong> <%= drink.iceAmount || 'N/A' %></li>
                        <li><strong>Special Notes:</strong> <%= drink.specialNotes || 'None' %></li>
                    </ul>
                    <div class="item-price">$<%= drink.basePrice ? drink.basePrice.toFixed(2) : '0.00' %></div>
                </article>
            <% }) %>
        <% } else { %>
            <div class="empty-message">No items in cart. <a href="/cashier/menu">Add items</a></div>
        <% } %>
    </div>
    
    <% if (drinks && drinks.length > 0) { %>
        <div class="summary">
            <h3>Order Summary</h3>
            <div>Items: <%= cartCount %></div>
            <div class="total">Total: $<%= cartTotal %></div>
        </div>
    <% } %>
    
    <footer>
        <button id="cancel-button" class="cancel-btn" onclick="cancelOrder()"><a href="/cashier/menu" style="text-decoration: none; color: #333;">Cancel Order</a></button>
        <% if (drinks && drinks.length > 0) { %>
            <button class="confirm-btn"><a href="/cashier/confirm">Confirm</a></button>
        <% } %>
    </footer>


    <script>
        const cancelButton = document.getElementById('cancel-button');

        async function cancelOrder() {
            try {
                const response = await fetch("/cashier/menu/clear-cart", {
                    method: "POST",
                });

                if (!response.ok) {
                    throw new Error(`Response status: ${response.status}`);
                }

                const result = await response.json();
                console.log("Response: ", result);

                const menuURL = new URL('./menu', window.location.href);

                console.log(menuURL);

                location.replace(menuURL);
        

            } catch (error) {
                console.error(error.message);
            }

        }

    </script>

</body>
</html>