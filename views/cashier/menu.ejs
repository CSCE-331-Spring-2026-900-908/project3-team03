            <p>Ice: extra</p>

            <p>Addons: grass jelly</p>

            <div class="order-item-buttons">
            <button class="modify-item-button"><a href="/cashier/customize">Modify</a></button>
            <button class="remove-item-button">Remove</button>
            </div>
        </article>

        <button class="cancel-order-button">Cancel Order</button>
        <button class="checkout-button"><a href="/cashier/checkout">Checkout</a></button>
    </aside>
    
    <main>
        <header>
            <h1>Cashier POS Interface</h1>
        </header>
        
        <nav class="category-select">
