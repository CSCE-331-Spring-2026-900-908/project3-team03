        <div class="add-drinks-menu">
            <button class="customize-new-item-button"><a href="/cashier/customize">Placeholder Drink</a></button>
            <button class="customize-new-item-button"><a href="/cashier/customize">Placeholder Drink</a></button>
            <button class="customize-new-item-button"><a href="/cashier/customize">Placeholder Drink</a></button>
            <button class="customize-new-item-button"><a href="/cashier/customize">Placeholder Drink</a></button>
            <button class="customize-new-item-button"><a href="/cashier/customize">Placeholder Drink</a></button>
            <button class="customize-new-item-button"><a href="/cashier/customize">Placeholder Drink</a></button>
            <button class="customize-new-item-button"><a href="/cashier/customize">Placeholder Drink</a></button>
            <button class="customize-new-item-button"><a href="/cashier/customize">Placeholder Drink</a></button>
            <button class="customize-new-item-button"><a href="/cashier/customize">Placeholder Drink</a></button>
            <button class="customize-new-item-button"><a href="/cashier/customize">Placeholder Drink</a></button>
            <button class="customize-new-item-button"><a href="/cashier/customize">Placeholder Drink</a></button>
            <button class="customize-new-item-button"><a href="/cashier/customize">Placeholder Drink</a></button>
            <button class="customize-new-item-button"><a href="/cashier/customize">Placeholder Drink</a></button>
            <button class="customize-new-item-button"><a href="/cashier/customize">Placeholder Drink</a></button>
        </div>
    </main>
    </div>

</body>
</html>