        function setCategory(newCategory, buttonName) {
            categorySelectButtons.forEach((button) => {
                button.className = 'category-button';
            });
            currentCategoryButton = document.getElementById(buttonName);
            currentCategoryButton.className = 'category-button-active';
            currentCategory = newCategory;
            renderMenu();
        }

        function renderMenu() {
            addDrinksMenu.innerHTML = '';
            
            if (currentCategory.localeCompare("All") == 0) {
                ['Milk Tea', 'Tea', 'Fruit Tea', 'Smoothie', 'Energy', 'SEASONAL'].forEach((category) => {
                    menuData.categories[category].forEach((item) => {
                        const button = document.createElement('button');
                        button.className = 'customize-new-item-button';
                        button.type = 'button';
                        button.onclick = function(){loadAddDrinkDialog(item.id)};
                        button.innerHTML = `${item.name} - $${item.price.toFixed(2)}`;
                        addDrinksMenu.appendChild(button);
                    });
                });
            }
            
            else if (!currentCategory || !menuData.categories[currentCategory] || menuData.categories[currentCategory].length === 0) {
                addDrinksMenu.innerHTML = '<div class="muted">No items in this category</div>';
                return;
            }

            menuData.categories[currentCategory].forEach((item) => {
                const button = document.createElement('button');
                button.className = 'customize-new-item-button';
                button.type = 'button';
                button.onclick = function(){loadAddDrinkDialog(item.id)};
                button.innerHTML = `${item.name} - $${item.price.toFixed(2)}`;
                addDrinksMenu.appendChild(button);
            });

        }

        async function clearCart() {
            
            try {
                const response = await fetch("/cashier/menu/clear-cart", {
                    method: "POST",
                });

                if (!response.ok) {
                    throw new Error(`Response status: ${response.status}`);
                }

                const result = await response.json();
                console.log("Response: ", result);

                const menuURL = new URL('./menu', window.location.href);

                console.log(menuURL);

                location.replace(menuURL);
        

            } catch (error) {
                console.error(error.message);
            }

        }

        function removeDrink(index) {
            if (confirm('Remove this item from the order?')) {
                fetch('/cashier/checkout/remove-drink', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ drinkIndex: index })
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Error removing item');
                    }
                })
                .catch(err => {
                    console.error('Error:', err);
                    alert('Error removing item');
                });
            }
        }

        function checkoutOrder() {
            const checkoutURL = new URL('./checkout', window.location.href);


            location.replace(checkoutURL);
        }

