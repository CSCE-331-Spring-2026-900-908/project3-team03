<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cashier Interface</title>
    <style>
        body {
            background: #f1f1f1;
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;

        }
        .layout {
            display: flex;
            min-height: 100vh;
        }

        .order-display {
            width: 25vw;
            background: #a2a2a2;
            border-right: 1px solid rgb(0, 1, 67);
            padding: 20px;
        }

        .order-item {
            border-radius: 10px;
            background-color: #e7e6e6;
            padding: 10px;
            margin-bottom: 20px;
            list-style: none;
        }

        .order-item h2 {
            margin-top: 10px;
        }

        .order-item ul {
            list-style: none;
        }

        .order-item-buttons {
            display: flex;
            flex-direction: row-reverse;
            gap: 10px;
        }

        .remove-item-button {
            height: 30px;
            background: #f1f1f1;
            border-radius: 15px;
        }
        
        .remove-item-button:hover{
            background: #d0d0d0;
        }

        .modify-item-button {
            background: #6e6e6e;
            color: white;
            border-radius: 15px;
        }

        .modify-item-button:hover {
            background: #959595;
        }

        .modify-item-button a {
            text-decoration: none;
            color: white;
        }

        .checkout-button {
            height: 50px;
            width: 100px;
            border-radius: 50px;
            background: rgb(62, 62, 113);
            color: white;
        }

        .checkout-button:hover {
            background: rgb(114, 122, 154);
        }

        .checkout-button a {
            color: white;
            text-decoration: none;
        }

        .cancel-order-button {
            height: 50px;
            width: 100px;
            border-radius: 50px;
            background: rgb(238, 238, 238);
            color: rgb(58, 58, 58);
        }

        .cancel-order-button:hover {
            background: rgb(203, 203, 203);
        }

        

        main {
            padding: 20px;
            width: 75vw;
        }

        .category-select {
            display: flex;
            align-items: center;
            justify-content: space-evenly;
        }

        .category-button, .category-button-active {
            width: 100px;
            height: 50px;
            border-radius: 50px;
            text-align: center;
            background: rgb(58, 68, 116);
            color: white;
        }

        .category-button-active, .category-button:hover {
            background: white;
            color: black;
        }

        .add-drinks-menu {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr 1fr;
            grid-template-rows: 1fr 1fr 1fr 1fr;
            padding: 20px;
        }

        .customize-new-item-button {
            margin: 10px;
            height: 40px;
            background: rgb(194, 194, 194);
            border-radius: 10px;
            text-align: left;
        }

        .customize-new-item-button:hover {
            background: rgb(224, 224, 224);
        }

        .customize-new-item-button a {
            text-decoration: none;
            color: black;
        }

        .drink-dialog::open {
            display: flex;
            flex-direction: column;
            align-items: center;
            border-radius: 5px;
        }

        .drink-dialog h1 {
            text-align: center;
            margin-left: 50px;
            margin-right: 50px;
        }

        .panel {
            background: #eee;
            flex-grow: 1;
            width: 50vw;
            border: 1px solid black;
            border-radius: 5px; 
            padding: 10px;
            text-align: center;
            margin: 0px 50px 25px 50px;
        }

        .sugar-amount-button, .sugar-amount-button-active {
            height: 40px;
            width: 100px;
            background: #f1f1f1;
            border-radius: 5px;
            margin: 10px;
        }

        .sugar-amount-button:hover, .sugar-amount-button-active {
            background: #c8c8c8;
        }

        .ice-amount-button, .ice-amount-button-active {
            height: 40px;
            width: 100px;
            background: #f1f1f1;
            border-radius: 5px;
            margin: 10px;
        }

        .ice-amount-button:hover, .ice-amount-button-active{
            background: #c8c8c8;
        }

        .addon-panel {
            background: #eee;
            flex-grow: 4;
            width: 50vw;
            border: 1px solid black;
            border-radius: 10px; 
            text-align: center;
            padding: 10px;
            margin: 0px 50px 25px 50px;
        }

        .addon-customizer {
            display: flex;
            height: 30px;
            border: 2px solid black;
            border-radius: 5px;
            background: #c8c8c8;
            padding: 0px;
            margin: 10px;
            flex-direction: row;
            justify-content: right;
        }

        .addon-customizer-active {
            display: flex;
            height: 30px;
            border: 2px solid black;
            border-radius: 5px;
            background: #c2c3dc;
            padding: 0px;
            margin: 10px;
            flex-direction: row;
            justify-content: right;
        }

       
        .addon-customizer p {
            padding: 0;
            height: 20px;
            margin: 6px;
        }

        .addon-customizer-active p {
            padding: 0;
            height: 20px;
            margin: 6px;
        }

        .addon-customizer select {
            height: 20px;
            margin: 5px;
            background: #dfdfdf;
        }

        .addon-customizer-active select {
            height: 20px;
            margin: 5px;
            background: #dfdfdf;
        }

        .button-row {
            display: flex;
            flex-direction: row;
            justify-content: center;
        }
        
        .addon-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            
        }

        .bottom-buttons {
            margin: 50px;
            margin-top: 0px;
            margin-bottom: 25px;
            display: flex;
            flex-direction: row-reverse;
            
        }

        .confirm-button {
            height: 75px;
            background: #585a65;
            width: 150px;
            border-radius: 100px;
            margin-left: 20px;
            color: white;
            font-size: 16px;
        }

        .confirm-button:hover {
            background: #7b7e8c;
        }

        .cancel-button {
            height: 75px;
            background: #c9c9c9;
            width: 150px;
            border-radius: 100px;
            color: black;
            font-size: 16px;
        }

        .cancel-button:hover {
            background: #e0e0e0;
        }

        
        table { border-collapse: collapse; width: 50%; margin: 16px auto; }
        th, td { border: 1px solid #aaa; padding: 8px; text-align: left; }
        th { background: #eee; }
    </style>
</head>
<body>

    <div class="layout">
    <aside class="order-display">
        <h1>Current Order</h1>

        <% if (cartCount && cartCount > 0) { %>
            <% for (let i = 0; i < cartCount; i++) { %>
            <article class="order-item">
                <h2><%= locals.drinks && locals.drinks[i]?.menuItemName || 'Item ' + (i+1) %></h2>

                <p>$<%= locals.drinks && locals.drinks[i]?.basePrice ? locals.drinks[i].basePrice.toFixed(2) : '0.00' %></p>

                <p>Sugar: <%= locals.drinks && locals.drinks[i]?.sugarAmount%></p>

                <p>Ice: <%= locals.drinks && locals.drinks[i]?.iceAmount%></p>

                <p>Addons:</p>
                <% if (locals.drinks && locals.drinks[i].addonStrings && locals.drinks[i].addonStrings.length > 0) { %>
                    <ul> 
                    <% for (let j = 0; j < locals.drinks[i].addonStrings.length; j++) { %>
                    <li><%= locals.drinks[i].addonStrings[j] %></li>
                    <% } %>
                    </ul>
                <% } else {%>
                    <ul>
                        <li>None</li>
                    </ul>
                <% } %>
                
                
                

                <div class="order-item-buttons">
                <button class="modify-item-button" onclick='loadUpdateDrinkDialog(<%= i+1 %>, <%= locals.drinks[i].sugarAmount %>, <%= locals.drinks[i].iceAmount %>, <%- JSON.stringify(locals.drinks[i].addons) %>, <%= locals.drinks[i].menuItemId %>)'>Modify</button>
                <button class="remove-item-button" onclick="removeDrink(<%= i %>)">Remove</button>
                </div>
            </article>
            <% } %>
        <% } else { %>
            <p style="text-align: center; color: #111111;">No items in cart</p>
        <% } %>

        <button class="cancel-order-button" onclick="clearCart()">Cancel Order</button>
        <button class="checkout-button" onclick="checkoutOrder()">Checkout</button>
    </aside>
    
    
    <main>
        <header>
            <h1 id="category-header">Cashier POS Interface</h1>
        </header>

        <dialog class="drink-dialog" id="customize-dialog" closedby=none>
            <h1>Modify Drink</h1>

            <div class="panel">
                <h2>Sugar Amount</h2>

                <div class="button-row">
                <button class="sugar-amount-button" id="m-sugar-button-0" onclick="mSetSugarAmount(0, 'm-sugar-button-0')">0%</button>
                <button class="sugar-amount-button" id="m-sugar-button-25" onclick="mSetSugarAmount(25, 'm-sugar-button-25')">25%</button>
                <button class="sugar-amount-button-active" id="m-sugar-button-50" onclick="mSetSugarAmount(50, 'm-sugar-button-50')">50%</button>
                <button class="sugar-amount-button" id="m-sugar-button-75" onclick="mSetSugarAmount(75, 'm-sugar-button-75')">75%</button>
                <button class="sugar-amount-button" id="m-sugar-button-100" onclick="mSetSugarAmount(100, 'm-sugar-button-100')">100%</button>
                </div>
            </div>
            
            <div class="panel">
                <h2>Ice Amount</h2>
                <div class="button-row">
                <button class="ice-amount-button" id="m-ice-button-none" onclick="mSetIceAmount(0, 'm-ice-button-none')">None</button>
                <button class="ice-amount-button" id="m-ice-button-less" onclick="mSetIceAmount(30, 'm-ice-button-less')">Less</button>
                <button class="ice-amount-button-active" id="m-ice-button-normal" onclick="mSetIceAmount(60, 'm-ice-button-normal')">Normal</button>
                <button class="ice-amount-button" id="m-ice-button-extra" onclick="mSetIceAmount(90, 'm-ice-button-extra')">Extra</button>
                </div>
            </div>

            <div class="addon-panel">
                <h2>Addons</h2>
                <div class="addon-grid" id="m-addon-grid">
                <div class="addon-customizer">
                    <p>Placeholder</p>
                    <select>
                        <option>0</option>
                        <option>1</option>
                        <option>2</option>
                        <option>3</option>
                    </select>
                </div>
                </div>
            </div>

            <div class="bottom-buttons">
                <button id="confirm-update-drink-button" class="confirm-button" onclick="submitModification()">Add to Cart</button>
                <button id="cancel-update-drink-button" class="cancel-button">Cancel</button>
            </div>
        </dialog>

        <!--dialog for adding a new drink to the current order-->
        <dialog class ="drink-dialog" id="new-drink-dialog" closedby=none>
            <h1>Customize Drink</h1>

            <div class="panel">
                <h2>Sugar Amount</h2>

                <div class="button-row">
                <button class="sugar-amount-button" id="c-sugar-button-0" onclick="cSetSugarAmount(0, 'c-sugar-button-0')">0%</button>
                <button class="sugar-amount-button" id="c-sugar-button-25" onclick="cSetSugarAmount(25, 'c-sugar-button-25')">25%</button>
                <button class="sugar-amount-button-active" id="c-sugar-button-50" onclick="cSetSugarAmount(50, 'c-sugar-button-50')">50%</button>
                <button class="sugar-amount-button" id="c-sugar-button-75" onclick="cSetSugarAmount(75, 'c-sugar-button-75')">75%</button>
                <button class="sugar-amount-button" id="c-sugar-button-100" onclick="cSetSugarAmount(100, 'c-sugar-button-100')">100%</button>
                </div>
            </div>
            
            <div class="panel">
                <h2>Ice Amount</h2>
                <div class="button-row">
                <button class="ice-amount-button" id="c-ice-button-none" onclick="cSetIceAmount(0, 'c-ice-button-none')">None</button>
                <button class="ice-amount-button" id="c-ice-button-less" onclick="cSetIceAmount(30, 'c-ice-button-less')">Less</button>
                <button class="ice-amount-button-active" id="c-ice-button-normal" onclick="cSetIceAmount(60, 'c-ice-button-normal')">Normal</button>
                <button class="ice-amount-button" id="c-ice-button-extra" onclick="cSetIceAmount(90, 'c-ice-button-extra')">Extra</button>
                </div>
            </div>

            <div class="addon-panel">
                <h2>Addons</h2>
                <div class="addon-grid" id="c-addon-grid">
                <div class="addon-customizer">
                    <p>Placeholder</p>
                    <select>
                        <option>0</option>
                        <option>1</option>
                        <option>2</option>
                        <option>3</option>
                    </select>
                </div>
                </div>
            </div>

            <div class="bottom-buttons">
                <button id="confirm-add-to-order-button" class="confirm-button" onclick="submitCustomization()">Add to Cart</button>
                <button id="cancel-add-to-order-button" class="cancel-button">Cancel</button>
            </div>
        </dialog>
        
        <nav class="category-select" id="category-select">
            <button class="category-button" id="all-button" onclick="setCategory('All', 'all-button')">All</button>
            <button class="category-button" id="milk-tea-button" onclick="setCategory('Milk Tea', 'milk-tea-button')">Milk Teas</button>
            <button class="category-button" id="tea-button" onclick="setCategory('Tea', 'tea-button')">Teas</button>
            <button class="category-button" id="fruit-tea-button" onclick="setCategory('Fruit Tea', 'fruit-tea-button')">Fruit Teas</button>
            <button class="category-button" id="smoothie-button" onclick="setCategory('Smoothie', 'smoothie-button')">Smoothies</button>
            <button class="category-button" id="energy-button" onclick="setCategory('Energy', 'energy-button')">Energy</button>
            <button class="category-button" id="seasonal-button" onclick="setCategory('SEASONAL', 'seasonal-button')">Seasonal</button>
        </nav>
        
        <% if (statusMessage) { %>
            <div class="status-message"><%= statusMessage %></div>
        <% } %>

        <div class="add-drinks-menu" id="add-drinks-menu">
            <% if (menuItems && menuItems.length > 0) { %>
                <% menuItems.forEach(item => { %>
                <button class="customize-new-item-button" onclick="loadAddDrinkDialog(<%= item.menu_item_id %>)"><%= item.name %> - $<%= item.base_price %></button>
                <% }) %>
            <% } else { %>
                <p style="grid-column: 1/-1; text-align: center;">No menu items available</p>
            <% } %>
        </div>
    </main>
    </div>

    <script>
        let sugarAmount = 50;
        let iceAmount = 60;
        let currDrinkId = -1; //for modifying an item in the cart
        let currMenuItemId = -1;

        const addons = <%- JSON.stringify(addons) %>;

        const menuData = {
            categories: <%- JSON.stringify(categories || {}) %>,
        };

        const menuItemIdsAndPrices = [];
        ['Milk Tea', 'Tea', 'Fruit Tea', 'Smoothie', 'Energy', 'SEASONAL'].forEach((category) => {
            menuData.categories[category].forEach((item) => {
                let obj = {
                    id: item.id,
                    price: item.price
                }
                menuItemIdsAndPrices.push(obj);
            });
        });
        //console.log(menuItemIdsAndPrices);
        
        function getDrinkPriceById(menuItemId) {
            for (let i = 0; i < menuItemIdsAndPrices.length; i++) {
                let obj = menuItemIdsAndPrices[i];
                if (obj.id == menuItemId) {
                    return obj.price;
                }
            }
            return 6;
        }

        function howMany(id, idsToQuants) {
            for (let i = 0; i < idsToQuants.length; i++) {
                if (idsToQuants[i].id == id) {
                    return idsToQuants[i].quantity;
                }
            }
            return -1;
        }
        

        let currentCategory = 'All';
        const categorySelect = document.getElementById("category-select");
        const categorySelectButtons = [
            document.getElementById("all-button"),
            document.getElementById("milk-tea-button"),
            document.getElementById("tea-button"),
            document.getElementById("fruit-tea-button"),
            document.getElementById("smoothie-button"),
            document.getElementById("energy-button"),
            document.getElementById("seasonal-button")
        ];

        const cAddonGrid = document.getElementById('c-addon-grid');
        const cPageHeader = document.getElementById('c-page-header');
        const mAddonGrid = document.getElementById('m-addon-grid');
        const mPageHeader = document.getElementById('m-page-header');
        const cAddonCustomizers = [];
        const mAddonCustomizers = [];
        const cIceAmountButtons = [
            document.getElementById("c-ice-button-none"),
            document.getElementById("c-ice-button-less"),
            document.getElementById("c-ice-button-normal"),
            document.getElementById("c-ice-button-extra")
        ];
        const cSugarAmountButtons = [
            document.getElementById("c-sugar-button-0"),
            document.getElementById("c-sugar-button-25"),
            document.getElementById("c-sugar-button-50"),
            document.getElementById("c-sugar-button-75"),
            document.getElementById("c-sugar-button-100")
        ];
        const mIceAmountButtons = [
            document.getElementById("m-ice-button-none"),
            document.getElementById("m-ice-button-less"),
            document.getElementById("m-ice-button-normal"),
            document.getElementById("m-ice-button-extra")
        ];
        const mSugarAmountButtons = [
            document.getElementById("m-sugar-button-0"),
            document.getElementById("m-sugar-button-25"),
            document.getElementById("m-sugar-button-50"),
            document.getElementById("m-sugar-button-75"),
            document.getElementById("m-sugar-button-100")
        ];


        function cSetSugarAmount(newAmount, source) {
            const sourceButton = document.getElementById(source);
            sugarAmount = newAmount;
            cSugarAmountButtons.forEach(button => {
                button.className='sugar-amount-button';
            });
            sourceButton.className = 'sugar-amount-button-active';
        }

        function cSetIceAmount(newAmount, source) {
            const sourceButton = document.getElementById(source);
            iceAmount = newAmount;
            cIceAmountButtons.forEach(button => {
                button.className='ice-amount-button';
            });
            sourceButton.className = 'ice-amount-button-active';
        }

        function mSetSugarAmount(newAmount, source) {
            const sourceButton = document.getElementById(source);
            sugarAmount = newAmount;
            mSugarAmountButtons.forEach(button => {
                button.className='sugar-amount-button';
            });
            sourceButton.className = 'sugar-amount-button-active';
        }

        function mSetIceAmount(newAmount, source) {
            const sourceButton = document.getElementById(source);
            iceAmount = newAmount;
            mIceAmountButtons.forEach(button => {
                button.className='ice-amount-button';
            });
            sourceButton.className = 'ice-amount-button-active';
        }

        function cRenderAddons() {
            cAddonGrid.innerHTML = '';

            addons.forEach((addon) => {
                //console.log("addon: ", addon);
                const customizer = document.createElement('customizer');
                customizer.className = 'addon-customizer';
                customizer.innerHTML = `<p>${addon.name}</p>`;                
                
                const selector = document.createElement('select');
                selector.type = 'select';
                selector.innerHTML = `
                <option>0</option>
                <option>1</option>
                <option>2</option>
                <option>3</option>`;

                customizer.appendChild(selector);


                const obj = {
                    customizer: customizer,
                    data: {
                        name: addon.name,
                        id: addon.id,
                        select: selector
                    }
                };

                cAddonCustomizers.push(obj);
                cAddonGrid.appendChild(customizer);
            });
        }


        function mRenderAddons(addonsForThisDrink) {
            mAddonGrid.innerHTML = '';

            addons.forEach((addon) => {
                //console.log("addon: ", addon);
                const customizer = document.createElement('customizer');
                let amtOfAddonInDrink = howMany(addon.id, addonsForThisDrink);
               
                
                
                customizer.innerHTML = `<p>${addon.name}</p>`;                
                
                const selector = document.createElement('select');
                selector.type = 'select';
                selector.innerHTML = `
                <option>0</option>
                <option>1</option>
                <option>2</option>
                <option>3</option>`;

                customizer.appendChild(selector);

                 if (amtOfAddonInDrink > 0) {
                    customizer.className = 'addon-customizer-active';
                    selector.value = amtOfAddonInDrink;
                } else {
                    customizer.className = 'addon-customizer';
                }
                const obj = {
                    customizer: customizer,
                    data: {
                        name: addon.name,
                        id: addon.id,
                        select: selector
                    }
                };

                mAddonCustomizers.push(obj);
                mAddonGrid.appendChild(customizer);
            });
        }

        const addDrinkDialog = document.getElementById("new-drink-dialog");

        const customizeDrinkDialog = document.getElementById("customize-dialog");
        const addDrinkButton = document.getElementById("confirm-add-to-order-button");
        const cancelAddToOrderButton = document.getElementById("cancel-add-to-order-button");

        const updateDrinkButton = document.getElementById('confirm-update-drink-button');
        const cancelUpdateDrinkButton = document.getElementById("cancel-update-drink-button");

        addDrinkButton.addEventListener("click", () => {
            addDrinkDialog.close();
            location.reload();
        });

        updateDrinkButton.addEventListener("click", () => {
            customizeDrinkDialog.close();
            location.reload();
        })

        cancelUpdateDrinkButton.addEventListener("click", () => {
            customizeDrinkDialog.close();
        });

        console.log("HERE");

        
        function loadUpdateDrinkDialog(cartId, oldSugarAmount, oldIceAmount, addonsForThisDrink, thisDrinkMenuItemId) {
            
            console.log("cartid: ", cartId);
            console.log("sugarAmount: ", oldSugarAmount);

            console.log("iceAmount: ", oldIceAmount);
            console.log("addons: ", addons);
            currDrinkId = cartId;
            currMenuItemId = thisDrinkMenuItemId;
            switch (oldSugarAmount) {
                case 0:
                    mSetSugarAmount(0, 'm-sugar-button-0');
                    break;
                case 25:
                    mSetSugarAmount(25, 'm-sugar-button-25');
                    break;
                case 50:
                    mSetSugarAmount(50, 'm-sugar-button-50');
                    break;
                case 75:
                    mSetSugarAmount(75, 'm-sugar-button-75');
                    break;
                case 100:
                    mSetSugarAmount(100, 'm-sugar-button-100');
                    break;
                default: 
                    mSetSugarAmount(50, 'm-sugar-button-50');
                    console.log('default case sugar');
                    break;
                    
            }

            switch (oldIceAmount) {
                case 0:
                    mSetIceAmount(0, 'm-ice-button-none');
                    break;
                case 30:
                    mSetIceAmount(30, 'm-ice-button-less');
                    break;
                case 60:
                    mSetIceAmount(60, 'm-ice-button-normal');
                    break;
                case 90:
                    mSetIceAmount(90, 'm-ice-button-extra');
                    break;
                default: 
                    mSetIceAmount(60, 'm-ice-button-normal');
                    console.log('default case ice');
                    break;
                    
            }

            mRenderAddons(addonsForThisDrink);

            customizeDrinkDialog.showModal();
            
        }



        function loadAddDrinkDialog(menuItemId) {
            sugarAmount = 50;
            iceAmount = 60;
            cRenderAddons();
            currMenuItemId = menuItemId;
            addDrinkDialog.showModal();

        }

        console.log("HERE2");

        cancelAddToOrderButton.addEventListener("click", () => {
            //console.log("Should close dialog");
            addDrinkDialog.close();
        });

        const addDrinksMenu = document.getElementById("add-drinks-menu");
       
        /*
        function initialize() {
            //categorySelect.innerHTML = '';
            categorySelectButtons = document.getElementsByClassName("category-button");
            categorySelectButtons.forEach((button) => {
