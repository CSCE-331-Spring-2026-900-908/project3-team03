<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cashier Interface</title>
    <style>
        body {
            background: #f1f1f1;
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;

        }
        .layout {
            display: flex;
            min-height: 100vh;
        }

        .order-display {
            width: 25vw;
            background: #a2a2a2;
            border-right: 1px solid rgb(0, 1, 67);
            padding: 20px;
        }

        .order-item {
            border-radius: 10px;
            background-color: #e7e6e6;
            padding: 10px;
            margin-bottom: 20px;
            list-style: none;
        }

        .order-item h2 {
            margin-top: 10px;
        }

        .order-item ul {
            list-style: none;
        }

        .order-item-buttons {
            display: flex;
            flex-direction: row-reverse;
            gap: 10px;
        }

        .remove-item-button {
            height: 30px;
            background: #f1f1f1;
            border-radius: 15px;
        }
        
        .remove-item-button:hover{
            background: #d0d0d0;
        }

        .modify-item-button {
            background: #6e6e6e;
            border-radius: 15px;
        }

        .modify-item-button:hover {
            background: #959595;
        }

        .modify-item-button a {
            text-decoration: none;
            color: white;
        }

        .checkout-button {
            height: 50px;
            width: 100px;
            border-radius: 50px;
            background: rgb(62, 62, 113);
            color: white;
        }

        .checkout-button:hover {
            background: rgb(114, 122, 154);
        }

        .checkout-button a {
            color: white;
            text-decoration: none;
        }

        .cancel-order-button {
            height: 50px;
            width: 100px;
            border-radius: 50px;
            background: rgb(238, 238, 238);
            color: rgb(58, 58, 58);
        }

        .cancel-order-button:hover {
            background: rgb(203, 203, 203);
        }

        

        main {
            padding: 20px;
            width: 75vw;
        }

        .category-select {
            display: flex;
            align-items: center;
            justify-content: space-evenly;
        }

        .category-button, .category-button-active {
            width: 100px;
            height: 50px;
            border-radius: 50px;
            text-align: center;
            background: rgb(58, 68, 116);
            color: white;
        }

        .category-button-active, .category-button:hover {
            background: white;
            color: black;
        }

        .add-drinks-menu {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr 1fr;
            grid-template-rows: 1fr 1fr 1fr 1fr;
            padding: 20px;
        }

        .customize-new-item-button {
            margin: 10px;
            height: 40px;
            background: rgb(194, 194, 194);
            border-radius: 10px;
            text-align: left;
        }

        .customize-new-item-button:hover {
            background: rgb(224, 224, 224);
        }

        .customize-new-item-button a {
            text-decoration: none;
            color: black;
        }


        
        table { border-collapse: collapse; width: 50%; margin: 16px auto; }
        th, td { border: 1px solid #aaa; padding: 8px; text-align: left; }
        th { background: #eee; }
    </style>
</head>
<body>

    <div class="layout">
    <aside class="order-display">
        <h1>Current Order</h1>

        <% if (cartCount && cartCount > 0) { %>
            <% for (let i = 0; i < cartCount; i++) { %>
            <article class="order-item">
                <h2><%= locals.drinks && locals.drinks[i]?.menuItemName || 'Item ' + (i+1) %></h2>

                <p>$<%= locals.drinks && locals.drinks[i]?.basePrice ? locals.drinks[i].basePrice.toFixed(2) : '0.00' %></p>

                <p>Sugar: <%= locals.drinks && locals.drinks[i]?.sugarAmount || 'N/A' %></p>

                <p>Ice: <%= locals.drinks && locals.drinks[i]?.iceAmount || 'N/A' %></p>

                <p>Special Notes: <%= locals.drinks && locals.drinks[i]?.specialNotes || 'None' %></p>

                <div class="order-item-buttons">
                <button class="modify-item-button"><a href="/cashier/customize">Modify</a></button>
                <button class="remove-item-button" onclick="removeDrink(<%= i %>)">Remove</button>
                </div>
            </article>
            <% } %>
        <% } else { %>
            <p style="text-align: center; color: #111111;">No items in cart</p>
        <% } %>

        <button class="cancel-order-button" onclick="clearCart()">Cancel Order</button>
        <button class="checkout-button"><a href="/cashier/checkout">Checkout</a></button>
    </aside>
    
    <main>
        <header>
            <h1 id="category-header">Cashier POS Interface</h1>
        </header>
        
        <nav class="category-select" id="category-select">
            <button class="category-button" id="all-button" onclick="setCategory('All', 'all-button')">All</button>
            <button class="category-button" id="milk-tea-button" onclick="setCategory('Milk Tea', 'milk-tea-button')">Milk Teas</button>
            <button class="category-button" id="tea-button" onclick="setCategory('Tea', 'tea-button')">Teas</button>
            <button class="category-button" id="fruit-tea-button" onclick="setCategory('Fruit Tea', 'fruit-tea-button')">Fruit Teas</button>
            <button class="category-button" id="smoothie-button" onclick="setCategory('Smoothie', 'smoothie-button')">Smoothies</button>
            <button class="category-button" id="energy-button" onclick="setCategory('Energy', 'energy-button')">Energy</button>
            <button class="category-button" id="seasonal-button" onclick="setCategory('SEASONAL', 'seasonal-button')">Seasonal</button>
        </nav>
        
        <% if (statusMessage) { %>
            <div class="status-message"><%= statusMessage %></div>
        <% } %>

        <div class="add-drinks-menu" id="add-drinks-menu">
            <% if (menuItems && menuItems.length > 0) { %>
                <% menuItems.forEach(item => { %>
                <button class="customize-new-item-button"><a href="/cashier/customize?menuItemId=<%= item.menu_item_id %>"><%= item.name %> - $<%= item.base_price %></a></button>
                <% }) %>
            <% } else { %>
                <p style="grid-column: 1/-1; text-align: center;">No menu items available</p>
            <% } %>
        </div>
    </main>
    </div>

    <script>
        const menuData = {
            categories: <%- JSON.stringify(categories || {}) %>,
        };
        let currentCategory = 'All';
        const categorySelect = document.getElementById("category-select");
        const categorySelectButtons = [
            document.getElementById("all-button"),
            document.getElementById("milk-tea-button"),
            document.getElementById("tea-button"),
            document.getElementById("fruit-tea-button"),
            document.getElementById("smoothie-button"),
            document.getElementById("energy-button"),
            document.getElementById("seasonal-button")
        ];

        const addDrinksMenu = document.getElementById("add-drinks-menu");
       
        /*
        function initialize() {
            //categorySelect.innerHTML = '';
            categorySelectButtons = document.getElementsByClassName("category-button");
            categorySelectButtons.forEach((button) => {
                button.addEventListner("click", renderCategory);
            });
            allButton = document.getElementById("all-button");
            allButton.className = "category-button-active";

        }
        */

        function setCategory(newCategory, buttonName) {
            categorySelectButtons.forEach((button) => {
                button.className = 'category-button';
            });
            currentCategoryButton = document.getElementById(buttonName);
            currentCategoryButton.className = 'category-button-active';
            currentCategory = newCategory;
            renderMenu();
        }

        function renderMenu() {
            addDrinksMenu.innerHTML = '';
            
            if (currentCategory.localeCompare("All") == 0) {
                ['Milk Tea', 'Tea', 'Fruit Tea', 'Smoothie', 'Energy', 'SEASONAL'].forEach((category) => {
                    menuData.categories[category].forEach((item) => {
                        const button = document.createElement('button');
                        button.className = 'customize-new-item-button';
                        button.type = 'button';
                        button.innerHTML = `<a href="/cashier/customize?menuItemId=${item.id}">${item.name} - $${item.price.toFixed(2)}</a>`;
                        addDrinksMenu.appendChild(button);
                    });
                });
            }
            
            else if (!currentCategory || !menuData.categories[currentCategory] || menuData.categories[currentCategory].length === 0) {
                addDrinksMenu.innerHTML = '<div class="muted">No items in this category</div>';
                return;
            }

            menuData.categories[currentCategory].forEach((item) => {
                const button = document.createElement('button');
                button.className = 'customize-new-item-button';
                button.type = 'button';
                button.innerHTML = `<a href="/cashier/customize?menuItemId=${item.id}">${item.name} - $${item.price.toFixed(2)}</a>`;
                addDrinksMenu.appendChild(button);
            });

        }

        function clearCart() {
            if (confirm('Are you sure you want to cancel this order?')) {
                // Clear session cart
                fetch('/cashier/menu', { method: 'GET' })
                    .then(r => r.text())
                    .then(() => location.reload());
            }
        }

        function removeDrink(index) {
            if (confirm('Remove this item from the order?')) {
                fetch('/cashier/checkout/remove-drink', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ drinkIndex: index })
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Error removing item');
                    }
                })
                .catch(err => {
                    console.error('Error:', err);
                    alert('Error removing item');
                });
            }
        }


    </script>

</body>
</html>